#!/usr/bin/env bash
# LingTu CLI — 灵途导航系统命令行工具
# 用法: ./lingtu <command> [options]
#
# 对标 DimOS 的 Blueprint.run() 一行启动体验

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
VERSION=$(cat "$SCRIPT_DIR/VERSION" 2>/dev/null || echo "dev")

# 颜色
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

# 默认值
MAP_DIR="${NAV_MAP_PATH:-/data/maps}"
DEFAULT_MAP="latest"
DEFAULT_SPEED="0.5"
DEFAULT_LLM="kimi"
SLAM_PROFILE="fastlio2"

banner() {
    echo -e "${CYAN}"
    echo "  ╦   ╦ ╔╗╔ ╔═╗ ╔╦╗ ╦ ╦"
    echo "  ║   ║ ║║║ ║ ╦  ║  ║ ║"
    echo "  ╩═╝ ╩ ╝╚╝ ╚═╝  ╩  ╚═╝"
    echo -e "  ${NC}${BOLD}灵途 v${VERSION}${NC} — 自主导航系统"
    echo ""
}

usage() {
    banner
    echo -e "${BOLD}用法:${NC} lingtu <command> [options]"
    echo ""
    echo -e "${BOLD}导航命令:${NC}"
    echo -e "  ${GREEN}map${NC}       [--save PATH]              建图模式 (手柄遥控 + SLAM)"
    echo -e "  ${GREEN}nav${NC}       [--map NAME] [--semantic]   导航模式 (加载地图 + 自主导航)"
    echo -e "  ${GREEN}explore${NC}   [TARGET]                    探索模式 (无需预建地图)"
    echo -e "  ${GREEN}agent${NC}     [--llm BACKEND]             Agent 模式 (LLM 大脑)"
    echo ""
    echo -e "${BOLD}快捷命令:${NC}"
    echo -e "  ${GREEN}go${NC}        TARGET                      语义导航 (\"去体育馆\")"
    echo -e "  ${GREEN}find${NC}      TARGET                      视觉搜索 (\"找红色椅子\")"
    echo -e "  ${GREEN}tag${NC}       NAME                        标记当前位置"
    echo -e "  ${GREEN}stop${NC}                                  立即停止"
    echo -e "  ${GREEN}say${NC}       TEXT                        对 Agent 说话"
    echo ""
    echo -e "${BOLD}系统命令:${NC}"
    echo -e "  ${GREEN}status${NC}                                查看系统状态"
    echo -e "  ${GREEN}health${NC}                                健康检查"
    echo -e "  ${GREEN}topics${NC}                                列出活跃话题"
    echo -e "  ${GREEN}save-map${NC}  [NAME]                      保存当前地图"
    echo -e "  ${GREEN}list-maps${NC}                             列出已有地图"
    echo -e "  ${GREEN}list-tags${NC}                             列出标记地点"
    echo ""
    echo -e "${BOLD}开发命令:${NC}"
    echo -e "  ${GREEN}build${NC}                                 编译 ROS2 工作空间"
    echo -e "  ${GREEN}test${NC}      [PACKAGE]                   运行测试"
    echo -e "  ${GREEN}stub${NC}      [nav|explore]               无硬件测试模式"
    echo ""
    echo -e "${BOLD}选项:${NC}"
    echo "  --speed SPEED       最大速度 m/s (默认: $DEFAULT_SPEED)"
    echo "  --slam PROFILE      SLAM 算法 (fastlio2/pointlio/stub)"
    echo "  --llm BACKEND       LLM 后端 (kimi/openai/mock)"
    echo "  --no-grpc           不启动 gRPC Gateway"
    echo "  --dry-run           只打印命令，不执行"
    echo "  -v, --verbose       详细输出"
    echo "  -h, --help          显示帮助"
    echo ""
    echo -e "${BOLD}示例:${NC}"
    echo "  lingtu map                          # 建图"
    echo "  lingtu nav --map office --semantic   # 语义导航"
    echo "  lingtu explore \"找到餐桌\"            # 语义探索"
    echo "  lingtu agent --llm kimi             # Agent 模式"
    echo "  lingtu go \"体育馆\"                   # 快捷导航"
    echo "  lingtu find \"红色椅子\"               # 视觉搜索"
    echo "  lingtu stub nav                     # 无硬件导航测试"
}

# ── Source ROS2 ──
source_ros2() {
    if [ -f /opt/ros/humble/setup.bash ]; then
        source /opt/ros/humble/setup.bash
    fi
    if [ -f "$SCRIPT_DIR/install/setup.bash" ]; then
        source "$SCRIPT_DIR/install/setup.bash"
    fi
}

# ── 解析全局选项 ──
SPEED="$DEFAULT_SPEED"
LLM_BACKEND="$DEFAULT_LLM"
MAP_NAME="$DEFAULT_MAP"
SEMANTIC_MAP=""
DRY_RUN=false
VERBOSE=false
ENABLE_SEMANTIC=false
ENABLE_AGENT=false
ENABLE_GRPC=true
EXTRA_ARGS=""

parse_global_opts() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --speed) SPEED="$2"; shift 2 ;;
            --slam) SLAM_PROFILE="$2"; shift 2 ;;
            --llm) LLM_BACKEND="$2"; shift 2 ;;
            --map) MAP_NAME="$2"; shift 2 ;;
            --semantic) ENABLE_SEMANTIC=true; shift ;;
            --agent) ENABLE_AGENT=true; shift ;;
            --no-grpc) ENABLE_GRPC=false; shift ;;
            --dry-run) DRY_RUN=true; shift ;;
            -v|--verbose) VERBOSE=true; shift ;;
            *) EXTRA_ARGS="$EXTRA_ARGS $1"; shift ;;
        esac
    done
}

# ── 执行或打印命令 ──
run_cmd() {
    local cmd="$1"
    if [ "$VERBOSE" = true ] || [ "$DRY_RUN" = true ]; then
        echo -e "${YELLOW}$ ${cmd}${NC}"
    fi
    if [ "$DRY_RUN" = false ]; then
        eval "$cmd"
    fi
}

# ── 推断语义地图路径 ──
resolve_semantic_map() {
    local map_path="$1"
    if [ -n "$SEMANTIC_MAP" ]; then
        echo "$SEMANTIC_MAP"
    elif [ -f "${map_path}_semantic.json" ]; then
        echo "${map_path}_semantic.json"
    else
        echo ""
    fi
}

# ════════════════════════════════════════
#  命令实现
# ════════════════════════════════════════

cmd_map() {
    banner
    echo -e "${GREEN}▶ 建图模式${NC} — 手柄遥控 + SLAM 建图"
    echo ""

    local semantic_flag=""
    local semantic_map_flag=""
    if [ "$ENABLE_SEMANTIC" = true ]; then
        echo -e "  ${CYAN}语义感知: 启用${NC}"
        semantic_flag="enable_semantic:=true"
        semantic_map_flag="semantic_map_path:=${MAP_DIR}/${MAP_NAME}_semantic.json"
    fi

    local cmd="ros2 launch $SCRIPT_DIR/launch/navigation_bringup.launch.py"
    cmd="$cmd maxSpeed:=$SPEED"
    cmd="$cmd slam_profile:=$SLAM_PROFILE"
    [ -n "$semantic_flag" ] && cmd="$cmd $semantic_flag $semantic_map_flag"

    echo -e "  ${CYAN}速度: ${SPEED} m/s | SLAM: ${SLAM_PROFILE}${NC}"
    echo ""
    run_cmd "$cmd"
}

cmd_nav() {
    banner
    echo -e "${GREEN}▶ 导航模式${NC} — 加载地图 + 自主导航"
    echo ""

    local map_path="${MAP_DIR}/${MAP_NAME}"
    local sem_map=$(resolve_semantic_map "$map_path")

    local cmd="ros2 launch $SCRIPT_DIR/launch/navigation_run.launch.py"
    cmd="$cmd map_path:=$map_path"
    cmd="$cmd maxSpeed:=$SPEED"
    cmd="$cmd slam_profile:=$SLAM_PROFILE"

    if [ "$ENABLE_SEMANTIC" = true ] || [ -n "$sem_map" ]; then
        cmd="$cmd enable_semantic:=true"
        [ -n "$sem_map" ] && cmd="$cmd semantic_map_path:=$sem_map"
        echo -e "  ${CYAN}语义导航: 启用${NC}"
    fi

    if [ "$ENABLE_AGENT" = true ]; then
        cmd="$cmd enable_agent:=true agent_llm_backend:=$LLM_BACKEND"
        echo -e "  ${CYAN}Agent: 启用 ($LLM_BACKEND)${NC}"
    fi

    echo -e "  ${CYAN}地图: $map_path | 速度: ${SPEED} m/s${NC}"
    echo ""
    run_cmd "$cmd"
}

cmd_explore() {
    banner
    local target="${EXTRA_ARGS# }"
    if [ -n "$target" ]; then
        echo -e "${GREEN}▶ 探索模式${NC} — 目标: ${BOLD}${target}${NC}"
    else
        echo -e "${GREEN}▶ 探索模式${NC} — 纯覆盖探索"
    fi
    echo ""

    local cmd="ros2 launch $SCRIPT_DIR/launch/navigation_explore.launch.py"
    cmd="$cmd maxSpeed:=$SPEED"
    cmd="$cmd slam_profile:=$SLAM_PROFILE"
    cmd="$cmd llm_backend:=$LLM_BACKEND"
    [ -n "$target" ] && cmd="$cmd target:=\"$target\""

    echo -e "  ${CYAN}速度: ${SPEED} m/s | LLM: ${LLM_BACKEND}${NC}"
    echo ""
    run_cmd "$cmd"
}

cmd_agent() {
    banner
    echo -e "${GREEN}▶ Agent 模式${NC} — LLM 大脑 + 全能力导航"
    echo ""

    ENABLE_SEMANTIC=true
    ENABLE_AGENT=true
    cmd_nav
}

cmd_go() {
    local target="${EXTRA_ARGS# }"
    if [ -z "$target" ]; then
        echo -e "${RED}错误: 请指定目标，如: lingtu go \"体育馆\"${NC}"
        exit 1
    fi
    echo -e "${GREEN}▶ 导航到: ${BOLD}${target}${NC}"
    run_cmd "ros2 topic pub --once /nav/semantic/instruction std_msgs/msg/String \"data: '$target'\""
}

cmd_find() {
    local target="${EXTRA_ARGS# }"
    if [ -z "$target" ]; then
        echo -e "${RED}错误: 请指定目标，如: lingtu find \"红色椅子\"${NC}"
        exit 1
    fi
    echo -e "${GREEN}▶ 视觉搜索: ${BOLD}${target}${NC}"
    run_cmd "ros2 topic pub --once /nav/semantic/bbox_navigate std_msgs/msg/String \"data: '{\\\"target\\\": \\\"$target\\\"}'\""
}

cmd_tag() {
    local name="${EXTRA_ARGS# }"
    if [ -z "$name" ]; then
        echo -e "${RED}错误: 请指定地点名称，如: lingtu tag \"体育馆\"${NC}"
        exit 1
    fi
    echo -e "${GREEN}▶ 标记位置: ${BOLD}${name}${NC}"
    run_cmd "ros2 topic pub --once /nav/semantic/tag_location std_msgs/msg/String \"data: '{\\\"name\\\": \\\"$name\\\"}'\""
}

cmd_say() {
    local text="${EXTRA_ARGS# }"
    if [ -z "$text" ]; then
        echo -e "${RED}错误: 请输入内容，如: lingtu say \"去厨房拿水\"${NC}"
        exit 1
    fi
    echo -e "${GREEN}▶ Agent: ${BOLD}${text}${NC}"
    run_cmd "ros2 topic pub --once /nav/agent/input std_msgs/msg/String \"data: '$text'\""
}

cmd_stop() {
    echo -e "${YELLOW}▶ 停止运动${NC}"
    run_cmd "ros2 topic pub --once /nav/semantic/bbox_navigate std_msgs/msg/String \"data: '{\\\"stop\\\": true}'\""
    # 发零速度
    run_cmd "ros2 topic pub --once /nav/cmd_vel geometry_msgs/msg/TwistStamped '{header: {frame_id: \"body\"}, twist: {linear: {x: 0.0}, angular: {z: 0.0}}}'"
}

cmd_status() {
    echo -e "${BOLD}=== LingTu 系统状态 ===${NC}"
    echo ""
    echo -e "${CYAN}活跃节点:${NC}"
    ros2 node list 2>/dev/null | grep -E "planner|perception|slam|driver|agent|grpc" || echo "  (无导航节点运行)"
    echo ""
    echo -e "${CYAN}关键话题:${NC}"
    for topic in /nav/odometry /nav/goal_pose /nav/cmd_vel /nav/semantic/scene_graph /nav/semantic/status /nav/agent/output; do
        hz=$(ros2 topic hz "$topic" --window 3 2>/dev/null | head -1 || echo "inactive")
        echo "  $topic: $hz"
    done
}

cmd_health() {
    echo -e "${BOLD}=== 健康检查 ===${NC}"
    run_cmd "bash $SCRIPT_DIR/scripts/health_check.sh"
}

cmd_topics() {
    ros2 topic list 2>/dev/null | grep "^/nav/" | sort
}

cmd_save_map() {
    local name="${EXTRA_ARGS# }"
    [ -z "$name" ] && name="$(date +%Y%m%d_%H%M%S)"
    echo -e "${GREEN}▶ 保存地图: ${name}${NC}"
    run_cmd "bash $SCRIPT_DIR/save_map.sh ${MAP_DIR}/${name}"
}

cmd_list_maps() {
    echo -e "${BOLD}=== 已有地图 ===${NC}"
    ls -la "${MAP_DIR}"/*.pcd 2>/dev/null || echo "  无地图文件"
    echo ""
    echo -e "${CYAN}语义地图:${NC}"
    ls -la "${MAP_DIR}"/*_semantic.json 2>/dev/null || echo "  无语义地图"
}

cmd_list_tags() {
    echo -e "${BOLD}=== 标记地点 ===${NC}"
    for f in "${MAP_DIR}"/*_tags.json; do
        [ -f "$f" ] || continue
        echo "  $f:"
        python3 -c "import json; [print(f'    {t[\"name\"]}: ({t[\"x\"]:.1f}, {t[\"y\"]:.1f})') for t in json.load(open('$f')).get('locations',[])]" 2>/dev/null
    done
}

cmd_build() {
    echo -e "${GREEN}▶ 编译${NC}"
    source_ros2
    run_cmd "cd $SCRIPT_DIR && colcon build --symlink-install"
}

cmd_test() {
    local pkg="${EXTRA_ARGS# }"
    source_ros2
    if [ -n "$pkg" ]; then
        echo -e "${GREEN}▶ 测试: ${pkg}${NC}"
        run_cmd "cd $SCRIPT_DIR && python -m pytest src/${pkg}/test/ -v"
    else
        echo -e "${GREEN}▶ 全部测试${NC}"
        run_cmd "cd $SCRIPT_DIR && make test"
    fi
}

cmd_stub() {
    local mode="${EXTRA_ARGS# }"
    SLAM_PROFILE="stub"
    case "$mode" in
        nav|navigation)
            echo -e "${GREEN}▶ 无硬件导航测试${NC}"
            run_cmd "ros2 launch $SCRIPT_DIR/launch/navigation_run.launch.py slam_profile:=stub planner_profile:=stub enable_semantic:=true"
            ;;
        explore|exploration)
            echo -e "${GREEN}▶ 无硬件探索测试${NC}"
            run_cmd "ros2 launch $SCRIPT_DIR/launch/navigation_explore.launch.py slam_profile:=stub llm_backend:=mock"
            ;;
        *)
            echo -e "${RED}用法: lingtu stub [nav|explore]${NC}"
            exit 1
            ;;
    esac
}

# ════════════════════════════════════════
#  主入口
# ════════════════════════════════════════

if [ $# -eq 0 ]; then
    usage
    exit 0
fi

COMMAND="$1"
shift

# 解析剩余参数
parse_global_opts "$@"

# Source ROS2 (导航命令需要)
case "$COMMAND" in
    map|nav|explore|agent|go|find|tag|say|stop|status|health|topics|save-map|build|test|stub)
        source_ros2
        ;;
esac

# 分发命令
case "$COMMAND" in
    map)        cmd_map ;;
    nav)        cmd_nav ;;
    explore)    cmd_explore ;;
    agent)      cmd_agent ;;
    go)         cmd_go ;;
    find)       cmd_find ;;
    tag)        cmd_tag ;;
    say)        cmd_say ;;
    stop)       cmd_stop ;;
    status)     cmd_status ;;
    health)     cmd_health ;;
    topics)     cmd_topics ;;
    save-map)   cmd_save_map ;;
    list-maps)  cmd_list_maps ;;
    list-tags)  cmd_list_tags ;;
    build)      cmd_build ;;
    test)       cmd_test ;;
    stub)       cmd_stub ;;
    -h|--help|help) usage ;;
    version|--version|-V) echo "LingTu v${VERSION}" ;;
    *)
        echo -e "${RED}未知命令: $COMMAND${NC}"
        echo "运行 'lingtu --help' 查看帮助"
        exit 1
        ;;
esac
