# ════════════════════════════════════════════════════════════
#  工具函数
# ════════════════════════════════════════════════════════════

source_ros2() {
    if [ -f /opt/ros/humble/setup.bash ]; then
        source /opt/ros/humble/setup.bash
    fi
    if [ -f "$SCRIPT_DIR/install/setup.bash" ]; then
        source "$SCRIPT_DIR/install/setup.bash"
    fi
    return 0
}

log_info()  { echo -e "  ${DOT} $1"; }
log_ok()    { echo -e "  ${OK} $1"; }
log_warn()  { echo -e "  ${WARN} $1"; }
log_fail()  { echo -e "  ${FAIL} $1"; }
log_run()   { echo -e "  ${RUN} ${B}$1${N}"; }

# 配置摘要面板
config_panel() {
    echo -e "  ${C}┌──────────────────────────────┐${N}"
    for line in "$@"; do
        printf "  ${C}│${N} %-35b${C}│${N}\n" "$line"
    done
    echo -e "  ${C}└──────────────────────────────┘${N}"
    echo ""
}

run_cmd() {
    local cmd="$1"
    if [ "$VERBOSE" = true ] || [ "$DRY_RUN" = true ]; then
        echo -e "  ${D}\$ ${cmd}${N}"
        echo ""
    fi
    if [ "$DRY_RUN" = false ]; then
        eval "$cmd"
    fi
    return 0
}

spinner() {
    local pid=$1 msg=$2
    local frames=('⠋' '⠙' '⠹' '⠸' '⠼' '⠴' '⠦' '⠧' '⠇' '⠏')
    local i=0
    while kill -0 "$pid" 2>/dev/null; do
        printf "\r  ${C}${frames[$i]}${N} ${msg}"
        i=$(( (i + 1) % ${#frames[@]} ))
        sleep 0.1
    done
    printf "\r"
}

# ── 全局选项 ──
SPEED="$DEFAULT_SPEED"
LLM_BACKEND="$DEFAULT_LLM"
MAP_NAME="$DEFAULT_MAP"
SEMANTIC_MAP=""
DRY_RUN=false
VERBOSE=false
ENABLE_SEMANTIC=false
ENABLE_AGENT=false
EXTRA_ARGS=""

parse_opts() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --speed)    SPEED="$2"; shift 2 ;;
            --slam)     SLAM_PROFILE="$2"; shift 2 ;;
            --llm)      LLM_BACKEND="$2"; shift 2 ;;
            --map)      MAP_NAME="$2"; shift 2 ;;
            --semantic) ENABLE_SEMANTIC=true; shift ;;
            --agent)    ENABLE_AGENT=true; shift ;;
            --dry-run)  DRY_RUN=true; shift ;;
            -v|--verbose) VERBOSE=true; shift ;;
            *)          EXTRA_ARGS="$EXTRA_ARGS $1"; shift ;;
        esac
    done
}

resolve_semantic_map() {
    local map_path="$1"
    [ -n "$SEMANTIC_MAP" ] && { echo "$SEMANTIC_MAP"; return; }
    [ -f "${map_path}_semantic.json" ] && { echo "${map_path}_semantic.json"; return; }
    echo ""
}

# ════════════════════════════════════════════════════════════
#  命令实现
# ════════════════════════════════════════════════════════════

cmd_map() {
    mini_banner
    log_run "建图模式"
    echo ""

    local sem="" sem_map=""
    if [ "$ENABLE_SEMANTIC" = true ]; then
        sem="enable_semantic:=true"
        sem_map="semantic_map_path:=${MAP_DIR}/${MAP_NAME}_semantic.json"
    fi

    config_panel \
        "${D}模式${N}    建图 (SLAM + 遥控)" \
        "${D}速度${N}    ${SPEED} m/s" \
        "${D}SLAM${N}    ${SLAM_PROFILE}" \
        "${D}语义${N}    $([ "$ENABLE_SEMANTIC" = true ] && echo "${G}启用${N}" || echo "${D}关闭${N}")"

    local cmd="ros2 launch $SCRIPT_DIR/launch/navigation_bringup.launch.py"
    cmd="$cmd maxSpeed:=$SPEED slam_profile:=$SLAM_PROFILE"
    [ -n "$sem" ] && cmd="$cmd $sem $sem_map"

    run_cmd "$cmd"
}

cmd_nav() {
    mini_banner
    log_run "导航模式"
    echo ""

    local map_path="${MAP_DIR}/${MAP_NAME}"
    local sem_map=$(resolve_semantic_map "$map_path")

    local sem_flag=""
    if [ "$ENABLE_SEMANTIC" = true ] || [ -n "$sem_map" ]; then
        sem_flag="enable_semantic:=true"
    fi

    local agent_flag=""
    if [ "$ENABLE_AGENT" = true ]; then
        agent_flag="enable_agent:=true agent_llm_backend:=$LLM_BACKEND"
    fi

    config_panel \
        "${D}模式${N}    导航 (定位 + 规划)" \
        "${D}地图${N}    ${MAP_NAME}" \
        "${D}速度${N}    ${SPEED} m/s" \
        "${D}SLAM${N}    ${SLAM_PROFILE}" \
        "${D}语义${N}    $([ -n "$sem_flag" ] && echo "${G}启用${N}" || echo "${D}关闭${N}")" \
        "${D}Agent${N}   $([ -n "$agent_flag" ] && echo "${G}${LLM_BACKEND}${N}" || echo "${D}关闭${N}")"

    local cmd="ros2 launch $SCRIPT_DIR/launch/navigation_run.launch.py"
    cmd="$cmd map_path:=$map_path maxSpeed:=$SPEED slam_profile:=$SLAM_PROFILE"
    [ -n "$sem_flag" ] && cmd="$cmd $sem_flag"
    [ -n "$sem_map" ] && cmd="$cmd semantic_map_path:=$sem_map"
    [ -n "$agent_flag" ] && cmd="$cmd $agent_flag"

    run_cmd "$cmd"
}

cmd_explore() {
    mini_banner
    local target="${EXTRA_ARGS# }"
    if [ -n "$target" ]; then
        log_run "探索模式 · 目标: ${B}${target}${N}"
    else
        log_run "探索模式 · 纯覆盖"
    fi
    echo ""

    config_panel \
        "${D}模式${N}    探索 (无需预建地图)" \
        "${D}目标${N}    ${target:-无 (纯覆盖)}" \
        "${D}速度${N}    ${SPEED} m/s" \
        "${D}LLM${N}     ${LLM_BACKEND}"

    local cmd="ros2 launch $SCRIPT_DIR/launch/navigation_explore.launch.py"
    cmd="$cmd maxSpeed:=$SPEED slam_profile:=$SLAM_PROFILE llm_backend:=$LLM_BACKEND"
    [ -n "$target" ] && cmd="$cmd target:=\"$target\""

    run_cmd "$cmd"
}

cmd_agent() {
    mini_banner
    log_run "Agent 大脑模式"
    echo ""

    config_panel \
        "${D}模式${N}    ${M}Agent 全自主${N}" \
        "${D}LLM${N}     ${LLM_BACKEND}" \
        "${D}能力${N}    导航 + 语义 + 视觉 + 记忆" \
        "${D}Skill${N}   navigate/find/tag/explore/stop"

    ENABLE_SEMANTIC=true
    ENABLE_AGENT=true
    cmd_nav
}

# 检查导航系统是否有订阅者
check_nav_running() {
    local topic="$1"
    local subs
    subs=$(ros2 topic info "$topic" 2>/dev/null | grep "Subscription count:" | awk '{print $NF}')
    if [ "${subs:-0}" = "0" ]; then
        log_warn "导航系统未运行"
        echo -e "  ${D}请先启动: lingtu nav --map <名称> --semantic${N}"
        echo -e "  ${D}或测试模式: lingtu stub nav${N}"
        return 1
    fi
    return 0
}

cmd_go() {
    local target="${EXTRA_ARGS# }"
    [ -z "$target" ] && { log_fail "请指定目标: ${W}lingtu go \"体育馆\"${N}"; exit 1; }
    mini_banner
    check_nav_running "/nav/semantic/instruction" || return 0
    log_run "导航到 ${B}${target}${N}"
    run_cmd "ros2 topic pub --once /nav/semantic/instruction std_msgs/msg/String \"data: '$target'\""
    log_ok "指令已发送"
}

cmd_find() {
    local target="${EXTRA_ARGS# }"
    [ -z "$target" ] && { log_fail "请指定目标: ${W}lingtu find \"红色椅子\"${N}"; exit 1; }
    mini_banner
    check_nav_running "/nav/semantic/bbox_navigate" || return 0
    log_run "视觉搜索 ${B}${target}${N}"
    run_cmd "ros2 topic pub --once /nav/semantic/bbox_navigate std_msgs/msg/String \"data: '{\\\"target\\\": \\\"$target\\\"}'\""
    log_ok "搜索指令已发送"
}

cmd_tag() {
    local name="${EXTRA_ARGS# }"
    [ -z "$name" ] && { log_fail "请指定名称: ${W}lingtu tag \"入口\"${N}"; exit 1; }
    mini_banner
    check_nav_running "/nav/semantic/tag_location" || return 0
    log_run "标记位置 ${B}${name}${N}"
    run_cmd "ros2 topic pub --once /nav/semantic/tag_location std_msgs/msg/String \"data: '{\\\"name\\\": \\\"$name\\\"}'\""
    log_ok "已标记"
}

cmd_say() {
    local text="${EXTRA_ARGS# }"
    [ -z "$text" ] && { log_fail "请输入内容: ${W}lingtu say \"去厨房\"${N}"; exit 1; }
    mini_banner
    check_nav_running "/nav/agent/input" || return 0
    log_run "Agent ← ${B}${text}${N}"
    run_cmd "ros2 topic pub --once /nav/agent/input std_msgs/msg/String \"data: '$text'\""
    log_ok "已发送"
}

cmd_stop() {
    mini_banner
    log_run "${R}停止运动${N}"
    run_cmd "ros2 topic pub --once /nav/semantic/bbox_navigate std_msgs/msg/String \"data: '{\\\"stop\\\": true}'\"" 2>/dev/null || true
    run_cmd "ros2 topic pub --once /nav/cmd_vel geometry_msgs/msg/TwistStamped '{header: {frame_id: \"body\"}, twist: {linear: {x: 0.0}, angular: {z: 0.0}}}'" 2>/dev/null || true
    log_ok "已停止"
}

cmd_status() {
    mini_banner
    echo ""
    echo -e "  ${B}NODES${N}"
    local nodes
    nodes=$(ros2 node list 2>/dev/null | grep -E "planner|perception|slam|driver|agent|grpc|bridge|localizer" || true)
    if [ -n "$nodes" ]; then
        while IFS= read -r node; do
            echo -e "    ${OK} ${node}"
        done <<< "$nodes"
    else
        echo -e "    ${D}(无导航节点运行)${N}"
    fi

    echo ""
    echo -e "  ${B}TOPICS${N}"
    local check_topics=("/nav/odometry" "/nav/cmd_vel" "/nav/goal_pose" "/nav/semantic/scene_graph" "/nav/planner_status" "/nav/agent/output")
    for topic in "${check_topics[@]}"; do
        local info
        info=$(ros2 topic info "$topic" 2>/dev/null || true)
        local pubs subs
        pubs=$(echo "$info" | grep "Publisher count" | awk '{print $NF}' || echo "0")
        subs=$(echo "$info" | grep "Subscription count" | awk '{print $NF}' || echo "0")
        if [ "${pubs:-0}" -gt 0 ]; then
            echo -e "    ${OK} ${topic}  ${D}pub:${pubs} sub:${subs}${N}"
        else
            echo -e "    ${D}·  ${topic}  (inactive)${N}"
        fi
    done

    echo ""
    echo -e "  ${B}SYSTEM${N}"
    local cpu mem
    cpu=$(grep 'cpu ' /proc/stat 2>/dev/null | awk '{u=$2+$4; t=$2+$4+$5; printf "%.0f%%", u/t*100}' || echo "N/A")
    mem=$(free -m 2>/dev/null | awk '/Mem:/{printf "%dM/%dM (%.0f%%)", $3, $2, $3/$2*100}' || echo "N/A")
    echo -e "    ${D}CPU${N}  $cpu"
    echo -e "    ${D}MEM${N}  $mem"
    echo ""
}

cmd_health() {
    mini_banner
    echo ""
    if [ -f "$SCRIPT_DIR/scripts/health_check.sh" ]; then
        run_cmd "bash $SCRIPT_DIR/scripts/health_check.sh"
    else
        log_warn "health_check.sh 未找到"
    fi
}

cmd_topics() {
    ros2 topic list 2>/dev/null | grep "^/nav/" | sort | while read -r t; do
        echo -e "  ${DOT} ${t}"
    done
}

cmd_save_map() {
    local name="${EXTRA_ARGS# }"
    [ -z "$name" ] && name="$(date +%Y%m%d_%H%M%S)"
    mini_banner
    log_run "保存地图 → ${B}${name}${N}"
    run_cmd "bash $SCRIPT_DIR/save_map.sh ${MAP_DIR}/${name}"
    log_ok "地图已保存到 ${MAP_DIR}/${name}"
}

cmd_list_maps() {
    mini_banner
    echo ""
    echo -e "  ${B}MAPS${N}  ${D}${MAP_DIR}${N}"
    local found=false
    for f in "${MAP_DIR}"/*.pcd "${MAP_DIR}"/*.pickle; do
        [ -f "$f" ] || continue
        found=true
        local size=$(du -sh "$f" 2>/dev/null | awk '{print $1}')
        local base=$(basename "$f")
        local sem=""
        [ -f "${f%.*}_semantic.json" ] && sem=" ${G}+semantic${N}"
        [ -f "${f%.*}_tags.json" ] && sem="$sem ${M}+tags${N}"
        echo -e "    ${DOT} ${B}${base}${N}  ${D}${size}${N}${sem}"
    done
    [ "$found" = false ] && echo -e "    ${D}(无地图)${N}"
    echo ""
}

cmd_list_tags() {
    mini_banner
    echo ""
    echo -e "  ${B}TAGGED LOCATIONS${N}"
    local found=false
    for f in "${MAP_DIR}"/*_tags.json; do
        [ -f "$f" ] || continue
        found=true
        local base=$(basename "$f" _tags.json)
        echo -e "    ${D}── ${base} ──${N}"
        python3 -c "
import json, sys
try:
    data = json.load(open('$f'))
    locs = data.get('locations', [])
    for loc in locs:
        print(f'      $DOT {loc[\"name\"]:20s}  ({loc[\"x\"]:.1f}, {loc[\"y\"]:.1f})')
    if not locs: print('      (empty)')
except: print('      (parse error)')
" 2>/dev/null
    done
    [ "$found" = false ] && echo -e "    ${D}(无标记地点)${N}"
    echo ""
}

cmd_build() {
    mini_banner
    log_run "编译 ROS2 工作空间"
    source_ros2
    run_cmd "cd $SCRIPT_DIR && colcon build --symlink-install"
}

cmd_test() {
    local pkg="${EXTRA_ARGS# }"
    source_ros2
    if [ -n "$pkg" ]; then
        mini_banner
        log_run "测试 ${B}${pkg}${N}"
        run_cmd "cd $SCRIPT_DIR && python -m pytest src/${pkg}/test/ -v"
    else
        mini_banner
        log_run "全部测试"
        run_cmd "cd $SCRIPT_DIR && make test"
    fi
}

cmd_chat() {
    mini_banner
    log_run "交互对话模式"
    echo ""

    # 检查是否有 ROS2 Agent 在跑
    local has_agent=false
    if command -v ros2 &>/dev/null; then
        if ros2 node list 2>/dev/null | grep -q "agent_node"; then
            has_agent=true
        fi
    fi

    if [ "$has_agent" = true ]; then
        echo -e "  ${OK} Agent 节点在线 — 通过 ROS2 通信"
        echo -e "  ${D}输入自然语言指令，Agent 会自主决策执行${N}"
    else
        echo -e "  ${WARN} Agent 节点未运行 — 直接调用 LLM API"
        echo -e "  ${D}输入指令会直接发给 LLM，但无法执行机器人动作${N}"
    fi
    echo -e "  ${D}输入 quit/exit/q 退出, help 查看快捷命令${N}"
    echo ""

    local history_file="${SCRIPT_DIR}/.chat_history"
    touch "$history_file" 2>/dev/null || true

    while true; do
        echo -ne "  ${C}灵途${N} ${M}›${N} "
        read -r input || break

        # 空行跳过
        [ -z "$input" ] && continue

        # 退出
        case "$input" in
            quit|exit|q|bye) log_ok "再见"; break ;;
        esac

        # 快捷命令 (不需要 ROS2)
        case "$input" in
            help)
                echo -e "  ${B}快捷命令:${N}"
                echo -e "    ${G}go <目标>${N}       导航到目标"
                echo -e "    ${G}find <物体>${N}     视觉搜索"
                echo -e "    ${G}tag <名称>${N}      标记位置"
                echo -e "    ${G}stop${N}            停止运动"
                echo -e "    ${G}where${N}           当前位置"
                echo -e "    ${G}scene${N}           场景描述"
                echo -e "    ${G}status${N}          系统状态"
                echo -e "    ${G}quit${N}            退出"
                echo ""
                continue
                ;;
            stop)
                cmd_stop 2>/dev/null
                continue
                ;;
            status)
                cmd_status 2>/dev/null
                continue
                ;;
            where|where_am_i)
                if [ "$has_agent" = true ]; then
                    ros2 topic pub --once /nav/agent/input std_msgs/msg/String "data: '我现在在哪里'" 2>/dev/null
                    sleep 1
                    local resp=$(ros2 topic echo --once /nav/agent/output std_msgs/msg/String 2>/dev/null | head -5)
                    [ -n "$resp" ] && echo -e "  ${DOT} $resp" || echo -e "  ${D}(等待响应...)${N}"
                else
                    echo -e "  ${D}需要 Agent 节点在线${N}"
                fi
                continue
                ;;
            scene)
                if [ "$has_agent" = true ]; then
                    local sg=$(ros2 topic echo --once --no-arr /nav/semantic/scene_graph std_msgs/msg/String 2>/dev/null | head -3)
                    [ -n "$sg" ] && echo -e "  ${DOT} $sg" || echo -e "  ${D}(无场景图)${N}"
                else
                    echo -e "  ${D}需要导航系统在线${N}"
                fi
                continue
                ;;
        esac

        # go/find/tag 快捷前缀
        case "$input" in
            go\ *)
                local target="${input#go }"
                echo -e "  ${DOT} 导航到 ${B}${target}${N}"
                if [ "$has_agent" = true ]; then
                    ros2 topic pub --once /nav/semantic/instruction std_msgs/msg/String "data: '$target'" 2>/dev/null
                    echo -e "  ${OK} 指令已发送"
                else
                    echo -e "  ${D}需要导航系统在线${N}"
                fi
                continue
                ;;
            find\ *)
                local target="${input#find }"
                echo -e "  ${DOT} 视觉搜索 ${B}${target}${N}"
                if [ "$has_agent" = true ]; then
                    ros2 topic pub --once /nav/semantic/bbox_navigate std_msgs/msg/String "data: '{\"target\": \"$target\"}'" 2>/dev/null
                    echo -e "  ${OK} 搜索指令已发送"
                else
                    echo -e "  ${D}需要导航系统在线${N}"
                fi
                continue
                ;;
            tag\ *)
                local name="${input#tag }"
                echo -e "  ${DOT} 标记 ${B}${name}${N}"
                if [ "$has_agent" = true ]; then
                    ros2 topic pub --once /nav/semantic/tag_location std_msgs/msg/String "data: '{\"name\": \"$name\"}'" 2>/dev/null
                    echo -e "  ${OK} 已标记"
                else
                    echo -e "  ${D}需要导航系统在线${N}"
                fi
                continue
                ;;
        esac

        # 自然语言 → Agent 或直接 LLM
        if [ "$has_agent" = true ]; then
            # 通过 ROS2 发给 Agent Node
            ros2 topic pub --once /nav/agent/input std_msgs/msg/String "data: '$input'" 2>/dev/null
            echo -e "  ${D}(思考中...)${N}"
            # 等待响应 (最多 15 秒)
            local resp
            resp=$(timeout 15 ros2 topic echo --once /nav/agent/output std_msgs/msg/String 2>/dev/null | grep "data:" | head -1)
            if [ -n "$resp" ]; then
                # 提取 JSON 中的 response 字段
                local answer
                answer=$(echo "$resp" | python3 -c "
import sys, json
try:
    raw = sys.stdin.read().strip()
    # 去掉 'data: ' 前缀
    if raw.startswith(\"data: '\") or raw.startswith('data: \"'):
        raw = raw[7:-1]
    d = json.loads(raw)
    print(d.get('response', raw))
except:
    print(raw)
" 2>/dev/null)
                echo -e "  ${G}灵途${N} ${DOT} ${answer:-$resp}"
            else
                echo -e "  ${Y}(响应超时，Agent 可能仍在执行...)${N}"
            fi
        else
            # 无 ROS2 — 直接调 LLM API (如果有 key)
            local api_key="${MOONSHOT_API_KEY:-${OPENAI_API_KEY:-}}"
            if [ -n "$api_key" ]; then
                echo -e "  ${D}(调用 LLM...)${N}"
                local answer
                answer=$(python3 -c "
import os, json, sys
try:
    from openai import OpenAI
    key = os.environ.get('MOONSHOT_API_KEY', os.environ.get('OPENAI_API_KEY', ''))
    base = 'https://api.moonshot.cn/v1' if 'MOONSHOT_API_KEY' in os.environ else None
    client = OpenAI(api_key=key, base_url=base) if base else OpenAI(api_key=key)
    resp = client.chat.completions.create(
        model='moonshot-v1-auto' if base else 'gpt-4o-mini',
        messages=[
            {'role': 'system', 'content': '你是灵途(LingTu)，一个四足导航机器人的AI。简短回答。当前无法执行动作（离线模式），但可以回答问题和规划。'},
            {'role': 'user', 'content': '''$input'''}
        ],
        max_tokens=200,
    )
    print(resp.choices[0].message.content)
except Exception as e:
    print(f'LLM 调用失败: {e}')
" 2>/dev/null)
                echo -e "  ${G}灵途${N} ${DOT} ${answer}"
            else
                echo -e "  ${D}无 LLM API key，设置 MOONSHOT_API_KEY 或 OPENAI_API_KEY${N}"
            fi
        fi

        # 保存历史
        echo "$input" >> "$history_file" 2>/dev/null || true
    done
}

cmd_stub() {
    local mode="${EXTRA_ARGS# }"
    SLAM_PROFILE="stub"
    case "$mode" in
        nav|navigation)
            mini_banner
            log_run "无硬件导航测试"
            config_panel \
                "${D}模式${N}    ${Y}STUB${N} (无硬件)" \
                "${D}SLAM${N}    stub" \
                "${D}规划${N}    stub" \
                "${D}语义${N}    ${G}启用${N}"
            run_cmd "ros2 launch $SCRIPT_DIR/launch/navigation_run.launch.py slam_profile:=stub planner_profile:=stub enable_semantic:=true"
            ;;
        explore|exploration)
            mini_banner
            log_run "无硬件探索测试"
            config_panel \
                "${D}模式${N}    ${Y}STUB${N} 探索 (无硬件)" \
                "${D}SLAM${N}    stub" \
                "${D}LLM${N}     mock"
            run_cmd "ros2 launch $SCRIPT_DIR/launch/navigation_explore.launch.py slam_profile:=stub llm_backend:=mock"
            ;;
        *)
            log_fail "用法: ${W}lingtu stub nav${N}  或  ${W}lingtu stub explore${N}"
            exit 1
            ;;
    esac
}

# ════════════════════════════════════════════════════════════
#  主入口
# ════════════════════════════════════════════════════════════

[ $# -eq 0 ] && { usage; exit 0; }

COMMAND="$1"; shift
parse_opts "$@"

# Source ROS2
case "$COMMAND" in
    map|nav|explore|agent|chat|go|find|tag|say|stop|status|health|topics|save-map|build|test|stub)
        source_ros2 ;;
esac

case "$COMMAND" in
    map)        cmd_map ;;
    nav)        cmd_nav ;;
    explore)    cmd_explore ;;
    agent)      cmd_agent ;;
    chat)       cmd_chat ;;
    go)         cmd_go ;;
    find)       cmd_find ;;
    tag)        cmd_tag ;;
    say)        cmd_say ;;
    stop)       cmd_stop ;;
    status)     cmd_status ;;
    health)     cmd_health ;;
    topics)     cmd_topics ;;
    save-map)   cmd_save_map ;;
    list-maps)  cmd_list_maps ;;
    list-tags)  cmd_list_tags ;;
    build)      cmd_build ;;
    test)       cmd_test ;;
    stub)       cmd_stub ;;
    -h|--help|help) usage ;;
    -V|--version|version) echo "LingTu v${VERSION}" ;;
    *)
        log_fail "未知命令: ${W}${COMMAND}${N}"
        echo -e "  ${D}运行 lingtu --help 查看帮助${N}"
        exit 1
        ;;
esac
