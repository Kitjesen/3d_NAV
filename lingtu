DOT="${C}›${N}" RUN="${G}▶${N}"   STOP="${R}■${N}"

# ── 默认值 ──
MAP_DIR="${NAV_MAP_PATH:-/data/maps}"
DEFAULT_MAP="latest"
DEFAULT_SPEED="0.5"
DEFAULT_LLM="kimi"
SLAM_PROFILE="fastlio2"

