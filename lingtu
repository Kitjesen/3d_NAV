# ── 颜色 + 符号 ──
R='\033[0;31m'    G='\033[0;32m'    Y='\033[1;33m'
C='\033[0;36m'    B='\033[1m'       D='\033[2m'
M='\033[0;35m'    W='\033[0;37m'    N='\033[0m'
