# ============================================================
# LingTu .gitignore ‚Äî 2026-03-24 cleaned
# ============================================================

# ‚îÄ‚îÄ Third-party reference code (local only, not tracked) ‚îÄ‚îÄ
third_party/

# ‚îÄ‚îÄ ROS 2 build artifacts ‚îÄ‚îÄ
build/
install/
log/

# ‚îÄ‚îÄ ROS bag files ‚îÄ‚îÄ
*.bag
*.db3
*.mcap

# ‚îÄ‚îÄ Runtime state ‚îÄ‚îÄ
.lingtu/

# ‚îÄ‚îÄ Python ‚îÄ‚îÄ
__pycache__/
*.pyc
*.py[cod]
*$py.class
*.egg-info/
venv/
env/
.venv/
.pytest_cache/

# ‚îÄ‚îÄ C/C++ build artifacts ‚îÄ‚îÄ
*.o
*.so
*.a
*.dylib
*.exe
*.out

# ‚îÄ‚îÄ Model weights (large binaries ‚Äî distribute via release-models.yml) ‚îÄ‚îÄ
*.pt
*.pth
*.onnx
*.engine
*.bin
*.hbm
mobileclip2_b.ts

# ‚îÄ‚îÄ Large data / media files ‚îÄ‚îÄ
assets/media/*.mp4
*.tar
*.tar.gz
*.tgz
*.pcd
*.gif
*.bagol*
*.part

# ‚îÄ‚îÄ Maps & 3D assets (keep example files) ‚îÄ‚îÄ
maps/*.pcd
tools/videos/*.mp4
tools/videos/*.gif
!src/global_planning/PCT_planner/rsc/PCD/example.pcd
!src/global_planning/PCT_planner/rsc/tomogram/example.pickle

# ‚îÄ‚îÄ IDE / editor / tooling ‚îÄ‚îÄ
.vscode/
.idea/
.cursor/
.agents/
*.swp
*.swo
*~
.DS_Store

# ‚îÄ‚îÄ AI agent / OMC state ‚îÄ‚îÄ
**/.omc/
.chat_history

# ‚îÄ‚îÄ Temporary files ‚îÄ‚îÄ
*.tmp
*.temp
*.test
*.log

# ‚îÄ‚îÄ Keys / credentials ‚Äî NEVER commit ‚îÄ‚îÄ
keys/
*.pem

# ‚îÄ‚îÄ Build / dist artifacts ‚îÄ‚îÄ
dist/
**/target/

# ‚îÄ‚îÄ Flutter client ‚îÄ‚îÄ
client/flutter_monitor/.dart_tool/
client/flutter_monitor/.flutter-plugins
client/flutter_monitor/.flutter-plugins-dependencies
client/flutter_monitor/.packages
client/flutter_monitor/build/
client/flutter_monitor/linux/flutter/ephemeral/
client/flutter_monitor/web/.dart_tool/

# ‚îÄ‚îÄ Third-party (use scripts/clone_semantic_deps.sh to restore) ‚îÄ‚îÄ
third_party/
!third_party/.gitkeep
!third_party/tare_planner/
# tare_planner is a git submodule; track the link, ignore its contents

