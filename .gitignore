# ============================================================
# LingTu .gitignore — 2026-05-31 cleaned
# ============================================================

# ── Third-party reference code (local only, not tracked) ──
third_party/

# ── ROS 2 build artifacts ──
build/
install/
log/
!scripts/build/
!scripts/build/build_ros_workspace.sh

# ── ROS bag files ──
*.bag
*.db3
*.mcap

# ── Runtime state ──
.lingtu/
artifacts/
logs/
output/
MUJOCO_LOG.TXT
status.out

# ── Python ──
__pycache__/
*.pyc
*.py[cod]
*$py.class
*.egg-info/
venv/
env/
.venv/
.pytest_cache/
.pytest-tmp-map/
.tmp_pytest/
.tmp_pytest_clean/
.tmp/
.tmp_gateway_tests/
pytest_tmp/

# ── C/C++ build artifacts ──
*.o
*.so
*.pyd
*.dll
*.a
*.dylib
*.exe
*.out
src/nav/core/build_nb*/

# ── Model weights (large binaries — distribute via release-models.yml) ──
*.pt
*.pth
*.onnx
*.engine
*.bin
*.hbm
mobileclip2_b.ts

# ── Large data / media files ──
assets/media/*.mp4
*.tar
*.tar.gz
*.tgz
*.pcd
*.gif
*.bagol*
*.part

# ── Maps & 3D assets (keep example files) ──
maps/*.pcd
docs/media/videos/*.mp4
docs/media/videos/*.gif
!src/global_planning/PCT_planner/rsc/PCD/example.pcd
!src/global_planning/PCT_planner/rsc/tomogram/example.pickle

# ── IDE / editor / tooling ──
.vscode/
.idea/
.cursor/
.agents/
*.swp
*.swo
*~
.DS_Store

# ── AI agent / OMC state ──
**/.omc/
**/.omx/
.chat_history

# ── Temporary files ──
*.tmp
*.temp
*.test
*.log
*.bak

# ── Keys / credentials — NEVER commit ──
keys/
*.pem

# ── Build / dist artifacts ──
dist/
**/target/

# ── Flutter client ──
client/flutter_monitor/.dart_tool/
client/flutter_monitor/.flutter-plugins
client/flutter_monitor/.flutter-plugins-dependencies
client/flutter_monitor/.packages
client/flutter_monitor/build/
client/flutter_monitor/linux/flutter/ephemeral/
client/flutter_monitor/web/.dart_tool/

# ── Third-party (use scripts/clone_semantic_deps.sh to restore) ──
third_party/
!third_party/.gitkeep

# OR-Tools binaries fetched by scripts/build/fetch_ortools.sh — ~130 MB
# per arch, not committed. The or-tools/ directory below ships the
# .gitkeep placeholder only.
src/exploration/tare_planner/or-tools/*
!src/exploration/tare_planner/or-tools/.gitkeep

# ── Generated test/paper output ──
paper_figures/
pipeline_videos/
functional_test_output/
test_results/
artifacts/
src/semantic_perception/test_results/
det_*.jpg
det_*.png

# ── Vendored libs (use system install) ──
src/global_planning/PCT_planner/planner/lib/3rdparty/gtsam-4.1.1/

# ── Sim output (videos, benchmarks — too large for git) ──
sim/output/

# ── Sim datasets (too large for git) ──
sim/datasets/legkilo_all/

# ── Research reference repos (clone manually, see research/README.md) ──
research/semantic_map_refs/
!research/README.md

# ── MuJoCo temp XML ──
sim/robots/*/tmp*.xml

# ── Misc generated ──
generate_paper_figures*.py
src/global_planning/PCT_planner/planner/lib/3rdparty/
.claude/worktrees/
mobileclip_blt.ts
web/node_modules
.claude/
