paper_figures/
pipeline_videos/
functional_test_output/
test_results/
src/semantic_perception/test_results/
det_*.jpg
det_*.png

# ‚îÄ‚îÄ Vendored libs (use system install) ‚îÄ‚îÄ
src/global_planning/PCT_planner/planner/lib/3rdparty/gtsam-4.1.1/

# ‚îÄ‚îÄ Sim output (videos, benchmarks ‚Äî too large for git) ‚îÄ‚îÄ
sim/output/

# ‚îÄ‚îÄ Sim datasets (too large for git) ‚îÄ‚îÄ
sim/datasets/legkilo_all/

# ‚îÄ‚îÄ Research reference repos (clone manually, see research/README.md) ‚îÄ‚îÄ
research/semantic_map_refs/
!research/README.md

# ‚îÄ‚îÄ MuJoCo temp XML ‚îÄ‚îÄ
