[Unit]
Description=LingTu SLAM (Fast-LIO2)
After=lidar.service

[Service]
Type=simple
User=sunrise
WorkingDirectory=/opt/nav
ExecStart=/bin/bash -c 'source /opt/nav/scripts/services/env.sh && exec ros2 launch /opt/nav/launch/subsystems/slam.launch.py slam_profile:=fastlio2'
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
