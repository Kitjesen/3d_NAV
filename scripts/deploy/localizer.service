[Unit]
Description=LingTu ICP Localizer
After=slam.service

[Service]
Type=simple
User=sunrise
WorkingDirectory=/opt/nav
ExecStart=/bin/bash -c 'source /opt/nav/scripts/services/env.sh && exec ros2 run localizer localizer_node --ros-args -p config_path:=${NAV_DIR}/install/localizer/share/localizer/config/localizer.yaml'
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
