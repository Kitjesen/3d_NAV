#!/usr/bin/env bash
# lingtu — unified CLI for Lingtu operations + monitoring.
#
# 所有日常运维 + 建图/导航切换 + 状态查询的唯一入口。取代:
#   - scripts/mapping_status.sh
#   - scripts/lingtu_status.sh
#   - 零散 curl / systemctl 命令
#
# 用法:
#   lingtu status              # 一次状态快照
#   lingtu watch               # 持续监控 (watch -c -n 1)
#   lingtu map start           # 进 mapping 模式
#   lingtu map save <name>     # 保存地图 (PGO + DUFOMap + tomogram)
#   lingtu map end             # 结束当前 session → idle
#   lingtu map list            # 列出已保存地图
#   lingtu map restore <name>  # 恢复 DUFOMap 清洗前的备份 (.predufo → map.pcd)
#   lingtu nav start <map>     # 进 navigating 模式, 加载指定地图
#   lingtu nav stop            # 结束 (同 map end)
#   lingtu nav goal X Y [YAW]  # 发导航目标 (map frame)
#   lingtu svc status          # SLAM 相关服务状态
#   lingtu svc restart slam    # 重启 Fast-LIO2
#   lingtu svc restart all     # 重启 lingtu + 清飞值
#   lingtu log drift           # 看 drift watchdog 日志
#   lingtu log dufomap         # 看 DUFOMap 保存日志
#   lingtu log error           # 看最近报错
#   lingtu log tail            # 实时滚动 (journalctl -f)
#   lingtu health              # REST /api/v1/health 详情
#
# 本机使用 (Windows/Mac SSH 到 S100P):
#   ssh sunrise@192.168.66.190 "bash ~/data/SLAM/navigation/scripts/lingtu status"
#
# 建议设 alias 到本机 ~/.bashrc:
#   alias lingtu='ssh sunrise@192.168.66.190 "bash ~/data/SLAM/navigation/scripts/lingtu"'
#   alias lingwatch='ssh -t sunrise@192.168.66.190 "bash ~/data/SLAM/navigation/scripts/lingtu watch"'
#
# Current production service aliases:
#   lingtu svc status          # robot-* service state + legacy conflict warning
#   lingtu svc restart slam    # restart robot-fastlio2.service
#   lingtu svc restart localization # restart Fast-LIO2 + localizer in order
#   lingtu svc restart super_lio # restart robot-super-lio.service
#   lingtu svc restart all     # restart robot-lidar + SLAM + localizer + lingtu
#   lingtu doctor              # read-only service/topic/Gateway diagnostics
#   lingtu doctor --non-motion --json --strict
#   lingtu soak --duration 120 --json --strict # non-motion readiness soak
#   lingtu slamcheck super_lio # switch, verify Super-LIO Gateway contract, rollback
#   lingtu slamcompare --map <name> # localizer vs Super-LIO relocation non-motion gate
#   lingtu runtime-spec nav --endpoint real_s100p # resolved profile data-flow/frame contract
#   lingtu runtime-contract --json # canonical topics, frames, and runtime contracts
#   lingtu runtime-audit --json # static runtime contract guard
#   lingtu dataflow [topic] # Gateway + ModulePorts runtime flow, no ROS2 topic inspection
#   lingtu gateway-runtime-acceptance --acceptance-mode field # Gateway-only product acceptance
#   lingtu field-check [map-dir] # one-screen field readiness, optional saved-map provenance
#   lingtu inspection-check [map-dir] --point lobby # non-motion inspection-point acceptance pack
#   lingtu saved-map-artifact-gate <map-dir> # same-source saved-map/tomogram/occupancy gate
#   lingtu plan-preview --internal-only --strict # offline tomogram planner preview, no motion
#   lingtu routecheck --map <name> --goal X Y YAW # route A/B preflight, no motion
#   lingtu routecompare --map <name> --goal X Y YAW --allow-motion # route A/B motion run
#   lingtu evidence --duration 20 --json-out report.json # read-only runtime data-flow/frame evidence
set -u
GW="${GW:-http://localhost:5050}"
MAP_DIR="${MAP_DIR:-${NAV_MAP_DIR:-$HOME/data/nova/maps}}"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

lingtu_repo_root() {
    cd "$SCRIPT_DIR/.." && pwd
}

lingtu_python() {
    printf "%s\n" "${LINGTU_PYTHON:-python3}"
}

lingtu_has_option() {
    local opt="$1"
    shift || true
    local arg
    for arg in "$@"; do
        case "$arg" in
            "$opt"|"$opt"=*)
                return 0 ;;
        esac
    done
    return 1
}

# Colors (stripped when piping / non-tty)
if [ -t 1 ]; then
    B='\033[1m'; G='\033[32m'; Y='\033[33m'; R='\033[31m'; C='\033[36m'; M='\033[35m'; D='\033[2m'; N='\033[0m'
else
    B=''; G=''; Y=''; R=''; C=''; M=''; D=''; N=''
fi

# ── JSON helper (feed blob via stdin, run python snippet) ──
pjson() { echo "$1" | python3 -c "
import sys,json,math
try: d=json.load(sys.stdin)
except Exception:
    print('-'); sys.exit(0)
$2
" 2>/dev/null || echo '-'; }

resolve_relocation_map_name() {
    python3 - "$1" "$2" <<'PY'
import sys
from pathlib import Path

root = Path(sys.argv[1]).expanduser().resolve()
raw = sys.argv[2]
if not raw:
    sys.exit(1)
raw_path = Path(raw).expanduser()
candidate = raw_path if raw_path.is_absolute() else root / raw_path
try:
    rel = candidate.resolve(strict=False).relative_to(root)
except Exception:
    sys.exit(1)
if len(rel.parts) != 1:
    sys.exit(1)
name = rel.parts[0]
if not name or name in (".", "..") or "/" in name or "\\" in name:
    sys.exit(1)
print(name)
PY
}

lingtu_maps_root() {
    if [ -n "${NAV_MAP_DIR:-}" ]; then
        printf "%s\n" "$NAV_MAP_DIR"
        return 0
    fi
    if [ -n "${MAP_DIR:-}" ] && [ "$MAP_DIR" != "$HOME/data/nova/maps" ]; then
        printf "%s\n" "$MAP_DIR"
        return 0
    fi
    if [ -d "$HOME/data/nova/maps" ]; then
        printf "%s\n" "$HOME/data/nova/maps"
        return 0
    fi
    if [ -d "$HOME/data/lingtu/maps" ]; then
        printf "%s\n" "$HOME/data/lingtu/maps"
        return 0
    fi
    printf "%s\n" "${MAP_DIR:-$HOME/data/nova/maps}"
}

format_relocation_initial_pose() {
    python3 - "$1" "$2" "$3" <<'PY'
import sys

try:
    x, y, yaw = (float(v) for v in sys.argv[1:4])
except Exception:
    sys.exit(1)
print(f"[{x:.6f},{y:.6f},0.0,0.0,0.0,{yaw:.6f}]")
PY
}

navigation_active_cmd_source() {
    pjson "$1" 'c=d.get("control") or {}; s=c.get("active_cmd_source") or c.get("active_source") or "none"; print((s.get("name") or s.get("source") or s.get("owner") or "none") if isinstance(s,dict) else (s or "none"))'
}

routecheck_require_no_active_command_source() {
    local phase="${1:-route preflight}" navj nav_ok source source_l
    navj=$(curl -s --max-time 4 "$GW/api/v1/navigation/status" 2>/dev/null || echo '{}')
    nav_ok=$(pjson "$navj" 'print(str(isinstance(d, dict) and (d.get("state") is not None or bool(d.get("readiness")) or bool(d.get("control")))).lower())')
    if [ "$nav_ok" != "true" ]; then
        printf "${R}FAIL${N}: %s cannot verify command source from /api/v1/navigation/status\n" "$phase"
        return 1
    fi
    source=$(navigation_active_cmd_source "$navj")
    source_l=$(printf "%s" "$source" | tr '[:upper:]' '[:lower:]')
    case "$source_l" in
        ""|none|null|-)
            return 0 ;;
        *)
            printf "${R}FAIL${N}: %s refused while active_cmd_source=%s\n" "$phase" "$source"
            return 1 ;;
    esac
}

format_nav_goal_payload() {
    python3 - "$1" "$2" "$3" <<'PY'
import json
import math
import sys

try:
    x, y, yaw = (float(v) for v in sys.argv[1:4])
except Exception:
    sys.exit(1)
if not all(math.isfinite(v) for v in (x, y, yaw)):
    sys.exit(1)
print(json.dumps({"x": x, "y": y, "z": 0.0, "yaw": yaw}, separators=(",", ":")))
PY
}

format_nav_session_payload() {
    python3 - "$1" "$2" <<'PY'
import json
import sys

payload = {
    "mode": "navigating",
    "map_name": sys.argv[1],
    "slam_profile": sys.argv[2],
}
print(json.dumps(payload, separators=(",", ":")))
PY
}

nav_goal_precheck() {
    local payload="$1"
    local NAVJ CAN BLOCKERS ADVISORIES STATE PLANJ FEASIBLE COUNT PLANNER REASONS POLICY SAFETY_OK FALLBACK REJECTED
    NAVJ=$(curl -s --max-time 3 "$GW/api/v1/navigation/status" 2>/dev/null || echo '{}')
    CAN=$(pjson "$NAVJ" 'r=d.get("readiness") or {}; print(str(r.get("can_accept_goal", d.get("can_accept_goal", False))).lower())')
    BLOCKERS=$(pjson "$NAVJ" 'r=d.get("readiness") or {}; b=r.get("blockers") or []; print(",".join(map(str,b)) if isinstance(b,list) else str(b or ""))')
    ADVISORIES=$(pjson "$NAVJ" 'r=d.get("readiness") or {}; a=r.get("advisories") or []; print(",".join(map(str,a)) if isinstance(a,list) else str(a or ""))')
    STATE=$(pjson "$NAVJ" 'print(d.get("state","unknown"))')
    if [ "$CAN" != "true" ]; then
        printf "${R}FAIL${N}: navigation is not ready for goals (state=%s blockers=%s advisories=%s)\n" \
            "$STATE" "${BLOCKERS:-unknown}" "${ADVISORIES:-unknown}"
        return 1
    fi

    PLANJ=$(curl -s --max-time 8 -X POST -H "Content-Type: application/json" \
        -d "$payload" "$GW/api/v1/navigation/plan" 2>/dev/null || echo '{}')
    FEASIBLE=$(pjson "$PLANJ" 'print(str(bool(d.get("feasible"))).lower())')
    COUNT=$(pjson "$PLANJ" 'print(d.get("count","-"))')
    PLANNER=$(pjson "$PLANJ" 'print(d.get("selected_planner") or d.get("planner") or "-")')
    POLICY=$(pjson "$PLANJ" 'print(d.get("plan_safety_policy") or "-")')
    SAFETY_OK=$(pjson "$PLANJ" 's=d.get("path_safety") if isinstance(d.get("path_safety"),dict) else {}; v=s.get("ok","-"); print(str(v).lower() if isinstance(v,bool) else v)')
    FALLBACK=$(pjson "$PLANJ" 'print(d.get("fallback_reason") or "-")')
    REJECTED=$(pjson "$PLANJ" 'r=d.get("rejected_plans") or []; print(len(r) if isinstance(r,list) else 0)')
    REASONS=$(pjson "$PLANJ" 'r=d.get("reasons") or []; print(",".join(map(str,r)) if isinstance(r,list) else str(r or ""))')
    if [ "$FEASIBLE" != "true" ]; then
        printf "${R}FAIL${N}: navigation plan preview is not feasible (points=%s planner=%s policy=%s safety=%s fallback=%s rejected=%s reasons=%s)\n" \
            "$COUNT" "$PLANNER" "$POLICY" "$SAFETY_OK" "$FALLBACK" "$REJECTED" "${REASONS:-unknown}"
        return 1
    fi
    printf "${D}plan preview feasible: points=%s planner=%s policy=%s safety=%s fallback=%s rejected=%s${N}\n" \
        "$COUNT" "$PLANNER" "$POLICY" "$SAFETY_OK" "$FALLBACK" "$REJECTED"
    return 0
}

# ── Subcommand: status (one-shot status board) ──
cmd_status() {
    echo -e "${B}=== Lingtu @ $(date '+%H:%M:%S') ===${N}"
    local SESS HEALTH STATE PATHJ LOCJ
    SESS=$(curl -s --max-time 2 "$GW/api/v1/session" 2>/dev/null || echo '{}')
    LOCJ=$(curl -s --max-time 2 "$GW/api/v1/localization/status" 2>/dev/null || echo '{}')
    HEALTH=$(curl -s --max-time 2 "$GW/api/v1/health" 2>/dev/null || echo '{}')
    STATE=$(curl -s --max-time 2 "$GW/api/v1/state" 2>/dev/null || echo '{}')
    PATHJ=$(curl -s --max-time 2 "$GW/api/v1/path" 2>/dev/null || echo '{}')

    local MODE MAP CAN_M MC
    MODE=$(pjson "$SESS" 'print(d.get("mode","?"))')
    MAP=$(pjson "$SESS" 'print(d.get("active_map") or "-")')
    CAN_M=$(pjson "$SESS" 'print(d.get("can_start_mapping",False))')
    case "$MODE" in
        mapping|exploring) MC="${G}${MODE}${N}" ;;
        navigating)        MC="${C}${MODE}${N}" ;;
        idle)              MC="${D}${MODE}${N}" ;;
        *)                 MC="${R}${MODE}${N}" ;;
    esac
    printf "${B}[1] Session${N}   mode=%b  map=${C}%s${N}  can_map=%s\n" "$MC" "$MAP" "$CAN_M"

    local HZ LIVE LOC LOC_CAUSE HZC LOCC SLAM_BACKEND HEALTH_SOURCE RELOC_STATE
    local RECOVERY_SIGNAL SAVED_RELOC RESTART_RECOVERY RECOVERY_METHOD SLAM_EXTRA
    HZ=$(pjson "$HEALTH" 'print(d["sensors"]["slam"].get("hz","?"))')
    LIVE=$(pjson "$HEALTH" 'print(d.get("map_points",0))')
    LOC=$(pjson "$STATE" 'print(d.get("dialogue",{}).get("localization","-"))')
    LOC_CAUSE=$(pjson "$STATE" 'print(d.get("dialogue",{}).get("loc_root_cause","") or "")')
    SLAM_BACKEND=$(pjson "$LOCJ" 'print(d.get("backend") or d.get("localization_backend") or "-")')
    [ "$SLAM_BACKEND" = "-" ] && SLAM_BACKEND=$(pjson "$SESS" 'print(d.get("localization_backend") or "-")')
    HEALTH_SOURCE=$(pjson "$LOCJ" 'print(d.get("health_source") or d.get("localizer_health_source") or "-")')
    [ "$HEALTH_SOURCE" = "-" ] && HEALTH_SOURCE=$(pjson "$SESS" 'print(d.get("health_source") or "-")')
    RELOC_STATE=$(pjson "$LOCJ" 'print(d.get("relocalization_state") or "-")')
    [ "$RELOC_STATE" = "-" ] && RELOC_STATE=$(pjson "$SESS" 'print(d.get("relocalization_state") or "-")')
    RECOVERY_SIGNAL=$(pjson "$LOCJ" 'print(d.get("recovery_signal") or "-")')
    [ "$RECOVERY_SIGNAL" = "-" ] && RECOVERY_SIGNAL=$(pjson "$SESS" 'print(d.get("recovery_signal") or "-")')
    SAVED_RELOC=$(pjson "$LOCJ" 'v=d.get("saved_map_relocalization_supported", d.get("relocalization_supported")); print(v if v is not None else "-")')
    [ "$SAVED_RELOC" = "-" ] && SAVED_RELOC=$(pjson "$SESS" 'v=d.get("saved_map_relocalization_supported", d.get("relocalization_supported")); print(v if v is not None else "-")')
    RESTART_RECOVERY=$(pjson "$LOCJ" 'v=d.get("restart_recovery_supported"); print(v if v is not None else "-")')
    [ "$RESTART_RECOVERY" = "-" ] && RESTART_RECOVERY=$(pjson "$SESS" 'v=d.get("restart_recovery_supported"); print(v if v is not None else "-")')
    RECOVERY_METHOD=$(pjson "$LOCJ" 'print(d.get("recovery_method") or "-")')
    [ "$RECOVERY_METHOD" = "-" ] && RECOVERY_METHOD=$(pjson "$SESS" 'print(d.get("recovery_method") or "-")')
    SLAM_EXTRA=""
    case "$SLAM_BACKEND" in ""|-|None|null) ;; *) SLAM_EXTRA="${SLAM_EXTRA}  backend=${SLAM_BACKEND}" ;; esac
    case "$HEALTH_SOURCE" in ""|-|None|null) ;; *) SLAM_EXTRA="${SLAM_EXTRA}  health_src=${HEALTH_SOURCE}" ;; esac
    case "$RELOC_STATE" in ""|-|None|null) ;; *) SLAM_EXTRA="${SLAM_EXTRA}  relocal=${RELOC_STATE}" ;; esac
    case "$RECOVERY_SIGNAL" in ""|-|None|null) ;; *) SLAM_EXTRA="${SLAM_EXTRA}  recover=${RECOVERY_SIGNAL}" ;; esac
    case "$SAVED_RELOC" in ""|-|None|null) ;; *) SLAM_EXTRA="${SLAM_EXTRA}  saved_reloc=${SAVED_RELOC}" ;; esac
    case "$RESTART_RECOVERY" in ""|-|None|null) ;; *) SLAM_EXTRA="${SLAM_EXTRA}  restart_rec=${RESTART_RECOVERY}" ;; esac
    case "$RECOVERY_METHOD" in ""|-|None|null) ;; *) SLAM_EXTRA="${SLAM_EXTRA}  recovery_method=${RECOVERY_METHOD}" ;; esac
    if awk "BEGIN{exit !($HZ < 5)}" 2>/dev/null; then HZC="${R}${HZ}${N}"
    elif awk "BEGIN{exit !($HZ < 20)}" 2>/dev/null; then HZC="${Y}${HZ}${N}"
    else HZC="${G}${HZ}${N}"; fi
    case "$LOC" in
        GOOD|OK)  LOCC="${G}${LOC}${N}" ;;
        DEGRADED) LOCC="${Y}${LOC}${N}${D} (${LOC_CAUSE})${N}" ;;
        LOST)     LOCC="${R}${LOC}${N}${D} (${LOC_CAUSE})${N}" ;;
        *)        LOCC="$LOC" ;;
    esac
    printf "${B}[2] SLAM${N}      hz=${HZC}Hz  live_pts=%s  loc=%b%s\n" "$LIVE" "$LOCC" "$SLAM_EXTRA"

    local RX RY RZ YAW VX WZ ABSURD
    RX=$(pjson "$STATE" 'print(round(float(d["odometry"].get("x",0)),2))')
    RY=$(pjson "$STATE" 'print(round(float(d["odometry"].get("y",0)),2))')
    RZ=$(pjson "$STATE" 'print(round(float(d["odometry"].get("z",0)),2))')
    YAW=$(pjson "$STATE" 'print(round(math.degrees(float(d["odometry"].get("yaw",0))),1))')
    VX=$(pjson "$STATE" 'print(round(float(d["odometry"].get("vx",0)),2))')
    WZ=$(pjson "$STATE" 'print(round(float(d["odometry"].get("wz",0)),2))')
    ABSURD=$(pjson "$STATE" 'o=d["odometry"]; print(1 if max(abs(float(o.get("x",0))),abs(float(o.get("y",0))))>10000 else 0)')
    if [ "$ABSURD" = "1" ]; then
        printf "${B}[3] Robot${N}     ${R}ODOM DIVERGED${N} x=%s y=%s — watchdog 60s 内会救\n" "$RX" "$RY"
    else
        printf "${B}[3] Robot${N}     xy=(%s,%s) z=%s yaw=%s°  v=%sm/s w=%srad/s\n" "$RX" "$RY" "$RZ" "$YAW" "$VX" "$WZ"
    fi

    local MSTATE WP_I WP_T REPLAN SPEED DEG MSC DEGC
    MSTATE=$(pjson "$STATE" 'print(d.get("mission",{}).get("state","?"))')
    WP_I=$(pjson "$STATE" 'print(d.get("mission",{}).get("wp_index",0))')
    WP_T=$(pjson "$STATE" 'print(d.get("mission",{}).get("wp_total",0))')
    REPLAN=$(pjson "$HEALTH" 'print(d["sensors"]["navigation"].get("replan_count",0))')
    SPEED=$(pjson "$STATE" 'print(d.get("mission",{}).get("speed_scale",1.0))')
    DEG=$(pjson "$STATE" 'print(d.get("mission",{}).get("degeneracy","-"))')
    case "$MSTATE" in
        EXECUTING|PLANNING|SUCCEEDED) MSC="${G}${MSTATE}${N}" ;;
        FAILED|ABORTED)               MSC="${R}${MSTATE}${N}" ;;
        IDLE|STANDBY)                 MSC="${D}${MSTATE}${N}" ;;
        *)                            MSC="${Y}${MSTATE}${N}" ;;
    esac
    case "$DEG" in
        NONE|OK)  DEGC="${G}${DEG}${N}" ;;
        WARN)     DEGC="${Y}${DEG}${N}" ;;
        CRITICAL) DEGC="${R}${DEG}${N}" ;;
        *)        DEGC="$DEG" ;;
    esac
    printf "${B}[4] Mission${N}   state=%b  wp=%s/%s  replan=%s  speed=%s  deg=%b\n" "$MSC" "$WP_I" "$WP_T" "$REPLAN" "$SPEED" "$DEGC"

    local PPTS PSTATS
    PPTS=$(pjson "$PATHJ" 'p=d.get("path",[]); print(len(p) if isinstance(p,list) else 0)')
    if [ "$PPTS" = "0" ] || [ "$PPTS" = "-" ]; then
        printf "${B}[5] Path${N}      ${D}(no active plan)${N}\n"
    else
        PSTATS=$(echo "$PATHJ" | python3 -c "
import sys,json,math
try:
    d=json.load(sys.stdin); pts=d.get('path',[]); r=d.get('robot',{}) or {}
    if not pts: print('- - -'); sys.exit(0)
    L=sum(math.hypot(pts[i-1].get('x',0)-pts[i].get('x',0), pts[i-1].get('y',0)-pts[i].get('y',0)) for i in range(1,len(pts)))
    f=math.hypot(r.get('x',0)-pts[0].get('x',0), r.get('y',0)-pts[0].get('y',0))
    g=math.hypot(r.get('x',0)-pts[-1].get('x',0), r.get('y',0)-pts[-1].get('y',0))
    print(f'{L:.1f} {f:.2f} {g:.2f}')
except Exception: print('- - -')
" 2>/dev/null)
        read PLEN DN DGOAL <<< "$PSTATS"
        printf "${B}[5] Path${N}      pts=%s  len=%sm  next=%sm  goal=%sm\n" "$PPTS" "$PLEN" "$DN" "$DGOAL"
    fi

    local TELE TELE_N SAFETY SC
    TELE=$(pjson "$STATE" 'print(d.get("teleop",{}).get("active",False))')
    TELE_N=$(pjson "$STATE" 'print(d.get("teleop",{}).get("clients",0))')
    SAFETY=$(pjson "$STATE" 'print(d.get("safety",{}).get("level","-"))')
    case "$SAFETY" in
        0)   SC="${G}OK${N}" ;;
        1)   SC="${Y}WARN${N}" ;;
        2|3) SC="${R}STOP${N}" ;;
        *)   SC="$SAFETY" ;;
    esac
    printf "${B}[6] Ctrl${N}      teleop=%s(%s)  safety=%b\n" "$TELE" "$TELE_N" "$SC"

    local LATEST NAME MTIME PCD BAK PAT DUFO CLEAN DIRTY DROP PCT MAP_SAVE_SOURCE MAP_EXTRA
    MAP_SAVE_SOURCE=$(pjson "$LOCJ" 'print(d.get("map_save_source") or "-")')
    [ "$MAP_SAVE_SOURCE" = "-" ] && MAP_SAVE_SOURCE=$(pjson "$SESS" 'print(d.get("map_save_source") or "-")')
    MAP_EXTRA=""
    case "$MAP_SAVE_SOURCE" in ""|-|None|null) ;; *) MAP_EXTRA="  save_src=${MAP_SAVE_SOURCE}" ;; esac
    LATEST=$(ls -dt "$MAP_DIR"/*/ 2>/dev/null | head -1)
    if [ -n "$LATEST" ]; then
        NAME=$(basename "$LATEST")
        MTIME=$(stat -c '%y' "$LATEST" 2>/dev/null | cut -d' ' -f2 | cut -d. -f1)
        PCD="-"; BAK="-"; PAT="-"; DUFO=""
        [ -f "$LATEST/map.pcd" ]         && PCD=$(du -h "$LATEST/map.pcd" | cut -f1)
        [ -f "$LATEST/map.pcd.predufo" ] && BAK=$(du -h "$LATEST/map.pcd.predufo" | cut -f1)
        [ -d "$LATEST/patches" ]         && PAT=$(ls "$LATEST/patches" 2>/dev/null | wc -l)
        if [ -f "$LATEST/map.pcd" ] && [ -f "$LATEST/map.pcd.predufo" ]; then
            CLEAN=$(stat -c %s "$LATEST/map.pcd" | awk '{printf "%d",$1/16}')
            DIRTY=$(stat -c %s "$LATEST/map.pcd.predufo" | awk '{printf "%d",$1/16}')
            DROP=$((DIRTY-CLEAN))
            [ "$DIRTY" -gt 0 ] && PCT=$(awk -v d=$DROP -v t=$DIRTY 'BEGIN{printf "%.1f",100*d/t}') || PCT=0
            DUFO="${G}dufo -${DROP}pts (${PCT}%)${N}"
        fi
        printf "${B}[7] Map${N}       %s ${D}@%s${N}  map=%s  bak=%s  patches=%s%s  %b\n" "$NAME" "$MTIME" "$PCD" "$BAK" "$PAT" "$MAP_EXTRA" "$DUFO"
    else
        printf "${B}[7] Map${N}       ${D}(no maps)${N}%s\n" "$MAP_EXTRA"
    fi

    local LOG
    LOG=$(journalctl -u lingtu.service --since '10 min ago' --no-pager 2>/dev/null \
        | grep -iE 'drift_watchdog|dufomap|dynamic_filter|\[ERROR\]' \
        | grep -vE 'VectorMemory|sentence_trans|webrtc.*dispose' | tail -3)
    if [ -n "$LOG" ]; then
        printf "${B}[8] Log${N}       ${D}(recent drift/dufomap/error)${N}\n"
        echo "$LOG" | sed "s/^/             /"
    fi
}

# ── Subcommand: watch (persistent refresh) ──
cmd_watch() { exec watch -c -n "${1:-1}" bash "${BASH_SOURCE[0]}" status; }

# ── Subcommand: map ──
cmd_map() {
    local action="${1:-}"
    case "$action" in
        start)
            curl -s -X POST -H "Content-Type: application/json" -d '{"mode":"mapping"}' \
                "$GW/api/v1/session/start" | python3 -m json.tool ;;
        save)
            local name="${2:-}"
            [ -z "$name" ] && { echo "Usage: lingtu map save <name>"; exit 1; }
            echo -e "${D}Saving MapManager artifacts (PGO + DUFOMap + tomogram + occupancy)...${N}"
            curl -s -X POST -H "Content-Type: application/json" -d "{\"action\":\"save\",\"name\":\"$name\"}" \
                "$GW/api/v1/maps" | python3 -m json.tool ;;
        end|stop)
            curl -s -X POST "$GW/api/v1/session/end" | python3 -m json.tool ;;
        list|ls)
            curl -s "$GW/api/v1/maps" -X POST -H "Content-Type: application/json" \
                -d '{"action":"list"}' | python3 -m json.tool | head -60 ;;
        restore)
            local name="${2:-}"
            [ -z "$name" ] && { echo "Usage: lingtu map restore <name>"; exit 1; }
            echo -e "${D}Restoring map.pcd from DUFOMap pre-filter backup...${N}"
            local restore_json restore_ok rebuild_action rebuild_json rebuild_ok
            restore_json=$(curl -s -X POST -H "Content-Type: application/json" -d "{\"name\":\"$name\"}" \
                "$GW/api/v1/map/restore_predufo" 2>/dev/null || echo '{}')
            echo "$restore_json" | python3 -m json.tool 2>/dev/null || echo "$restore_json"
            restore_ok=$(pjson "$restore_json" 'print(str(d.get("success", False)).lower())')
            [ "$restore_ok" = "true" ] || { echo -e "${R}FAIL${N}: restore_predufo failed"; exit 1; }
            for rebuild_action in build_tomogram build_occupancy; do
                echo -e "${D}Rebuilding ${rebuild_action#build_} for $name...${N}"
                rebuild_json=$(curl -s -X POST -H "Content-Type: application/json" \
                    -d "{\"action\":\"$rebuild_action\",\"name\":\"$name\"}" \
                    "$GW/api/v1/maps" 2>/dev/null || echo '{}')
                echo "$rebuild_json" | python3 -m json.tool 2>/dev/null || echo "$rebuild_json"
                rebuild_ok=$(pjson "$rebuild_json" 'print(str(d.get("success", False)).lower())')
                [ "$rebuild_ok" = "true" ] || { echo -e "${R}FAIL${N}: $rebuild_action failed"; exit 1; }
            done ;;
        *) echo "Usage: lingtu map [start|save <name>|end|list|restore <name>]"; exit 1 ;;
    esac
}

# ── Subcommand: nav ──
cmd_nav() {
    local action="${1:-}"
    case "$action" in
        start)
            local map="${2:-}"
            [ -z "$map" ] && { echo "Usage: lingtu nav start <map>"; exit 1; }
            curl -s -X POST -H "Content-Type: application/json" \
                -d "{\"mode\":\"navigating\",\"map_name\":\"$map\"}" \
                "$GW/api/v1/session/start" | python3 -m json.tool ;;
        stop|end)
            curl -s -X POST "$GW/api/v1/session/end" | python3 -m json.tool ;;
        goal)
            local x="${2:-}"; local y="${3:-}"; local yaw="${4:-0}"
            local payload
            [ -z "$x" ] || [ -z "$y" ] && { echo "Usage: lingtu nav goal X Y [YAW]"; exit 1; }
            payload=$(format_nav_goal_payload "$x" "$y" "$yaw") || { echo "goal must be numeric X Y [YAW]"; exit 1; }
            nav_goal_precheck "$payload" || exit 1
            curl -s -X POST -H "Content-Type: application/json" \
                -d "$payload" \
                "$GW/api/v1/goal" | python3 -m json.tool ;;
        *) echo "Usage: lingtu nav [start <map>|stop|goal X Y [YAW]]"; exit 1 ;;
    esac
}

# ── Subcommand: svc ──
svc_unit() {
    case "${1:-}" in
        lidar)      echo "robot-lidar.service" ;;
        camera)     echo "robot-camera.service" ;;
        brainstem)  echo "robot-brainstem.service" ;;
        slam|fastlio2)
                    echo "robot-fastlio2.service" ;;
        localizer)  echo "robot-localizer.service" ;;
        super_lio|super-lio|superlio)
                    echo "robot-super-lio.service" ;;
        super_lio_relocation|super_lio_reloc|super-lio-relocation|super-lio-reloc|superlio-relocation|superlio-reloc|relocation)
                    echo "robot-super-lio-relocation.service" ;;
        lingtu|app) echo "lingtu.service" ;;
        robot-lidar|robot-lidar.service)
                    echo "robot-lidar.service" ;;
        robot-camera|robot-camera.service)
                    echo "robot-camera.service" ;;
        robot-brainstem|robot-brainstem.service)
                    echo "robot-brainstem.service" ;;
        robot-fastlio2|robot-fastlio2.service)
                    echo "robot-fastlio2.service" ;;
        robot-localizer|robot-localizer.service)
                    echo "robot-localizer.service" ;;
        robot-super-lio|robot-super-lio.service)
                    echo "robot-super-lio.service" ;;
        robot-super-lio-relocation|robot-super-lio-relocation.service)
                    echo "robot-super-lio-relocation.service" ;;
        lingtu.service)
                    echo "lingtu.service" ;;
        *)          return 1 ;;
    esac
}

print_service_row() {
    local svc="$1" label="${2:-$1}" en act
    en=$(systemctl is-enabled "$svc" 2>/dev/null | head -1 || echo '-')
    act=$(systemctl is-active  "$svc" 2>/dev/null | head -1 || echo '-')
    en="${en:-'-'}"
    act="${act:-'-'}"
    case "$act" in
        active)   act="${G}${act}${N}" ;;
        inactive) act="${D}${act}${N}" ;;
        failed)   act="${R}${act}${N}" ;;
    esac
    printf "  %-14s %-24s enabled=%-10s active=%b\n" "$label" "$svc" "$en" "$act"
}

warn_legacy_services() {
    local legacy active=()
    for legacy in lidar.service camera.service orbbec-camera.service slam.service localizer.service slam_pgo.service super_lio.service super-lio.service super_lio_relocation.service super_lio_reloc.service super-lio-relocation.service super-lio-reloc.service; do
        if [ "$(systemctl is-active "$legacy" 2>/dev/null || true)" = "active" ]; then
            active+=("$legacy")
        fi
    done
    if [ "${#active[@]}" -gt 0 ]; then
        printf "${Y}WARN${N}: legacy services are active and can conflict with robot-* stack: %s\n" "${active[*]}"
    fi
}

svc_force_stop_unit() {
    local unit="$1" pid active
    active=$(systemctl is-active "$unit" 2>/dev/null || true)
    case "$active" in
        inactive|failed|unknown|"")
            sudo systemctl reset-failed "$unit" 2>/dev/null || true
            return 0 ;;
    esac
    if timeout 20 sudo systemctl stop "$unit"; then
        sudo systemctl reset-failed "$unit" 2>/dev/null || true
        return 0
    fi
    pid=$(systemctl show "$unit" -p MainPID --value 2>/dev/null || echo 0)
    if [ "${pid:-0}" != "0" ]; then
        printf "${Y}WARN${N}: %s did not stop cleanly; killing pid %s\n" "$unit" "$pid"
        sudo kill -KILL "$pid" 2>/dev/null || true
        sleep 2
    fi
    sudo systemctl reset-failed "$unit" 2>/dev/null || true
}

svc_start_unit() {
    local unit="$1"
    sudo systemctl start "$unit"
}

svc_wait_topic_publishers() {
    local topic="$1" min_pubs="${2:-1}" timeout_s="${3:-15}" pubs i
    source_robot_env
    for i in $(seq 1 "$timeout_s"); do
        pubs=$(ros2 topic info "$topic" 2>/dev/null | awk '/Publisher count:/ {print $3}' | tail -1)
        pubs="${pubs:-0}"
        if [ "$pubs" -ge "$min_pubs" ] 2>/dev/null; then
            return 0
        fi
        sleep 1
    done
    return 1
}

svc_wait_gateway_ready() {
    local timeout_s="${1:-30}" i
    for i in $(seq 1 "$timeout_s"); do
        if curl -fsS --max-time 2 "$GW/ready" 2>/dev/null \
            | python3 -c 'import json,sys; sys.exit(0 if json.load(sys.stdin).get("ready") else 1)' 2>/dev/null; then
            return 0
        fi
        sleep 1
    done
    return 1
}

svc_restart_lidar_chain() {
    svc_force_stop_unit robot-lidar.service
    svc_start_unit robot-lidar.service
    if svc_wait_topic_publishers /nav/lidar_scan 1 20 && svc_wait_topic_publishers /nav/imu 1 10; then
        echo "robot-lidar.service restarted; LiDAR and IMU publishers are present"
        return 0
    fi
    echo "robot-lidar.service started but LiDAR/IMU publishers did not become ready" >&2
    journalctl -u robot-lidar.service -n 30 --no-pager >&2 || true
    return 1
}

svc_restart_localization_chain() {
    echo "Restarting localization algorithms top-down..."
    svc_force_stop_unit robot-localizer.service
    svc_force_stop_unit robot-fastlio2.service

    echo "Starting Fast-LIO2..."
    svc_start_unit robot-fastlio2.service
    if ! svc_wait_topic_publishers /nav/odometry 1 30; then
        echo "robot-fastlio2.service did not publish /nav/odometry in time" >&2
        journalctl -u robot-fastlio2.service -n 40 --no-pager >&2 || true
        return 1
    fi

    echo "Starting localizer..."
    svc_start_unit robot-localizer.service
    if ! svc_wait_topic_publishers /nav/localization_health 1 30; then
        echo "robot-localizer.service did not publish /nav/localization_health in time" >&2
        journalctl -u robot-localizer.service -n 40 --no-pager >&2 || true
        return 1
    fi

    if systemctl is-active --quiet lingtu.service; then
        if svc_wait_gateway_ready 35; then
            echo "localization stack restarted; /ready is true"
            return 0
        fi
        echo "localization stack restarted but /ready did not become true in time" >&2
        journalctl -u lingtu.service -n 60 --no-pager >&2 || true
        return 1
    fi

    echo "localization stack restarted; lingtu.service is not active"
}

svc_restart_robot_stack() {
    echo "Stopping LingTu localization stack top-down..."
    svc_force_stop_unit lingtu.service
    svc_force_stop_unit robot-super-lio-relocation.service
    svc_force_stop_unit robot-super-lio.service
    svc_force_stop_unit robot-localizer.service
    svc_force_stop_unit robot-fastlio2.service

    echo "Starting LiDAR..."
    svc_restart_lidar_chain || return 1

    echo "Starting Fast-LIO2..."
    svc_start_unit robot-fastlio2.service
    if ! svc_wait_topic_publishers /nav/odometry 1 30; then
        echo "robot-fastlio2.service did not publish /nav/odometry in time" >&2
        journalctl -u robot-fastlio2.service -n 40 --no-pager >&2 || true
        return 1
    fi

    echo "Starting localizer..."
    svc_start_unit robot-localizer.service
    if ! svc_wait_topic_publishers /nav/localization_health 1 30; then
        echo "robot-localizer.service did not publish /nav/localization_health in time" >&2
        journalctl -u robot-localizer.service -n 40 --no-pager >&2 || true
        return 1
    fi

    echo "Starting LingTu Gateway/runtime..."
    svc_start_unit lingtu.service
    if svc_wait_gateway_ready 45; then
        echo "robot LiDAR + SLAM + localizer + lingtu restarted; /ready is true"
        return 0
    fi
    echo "LingTu started but /ready did not become true in time" >&2
    journalctl -u lingtu.service -n 60 --no-pager >&2 || true
    return 1
}

cmd_svc() {
    local action="${1:-status}"
    case "$action" in
        status)
            print_service_row robot-lidar.service lidar
            print_service_row robot-camera.service camera
            print_service_row robot-brainstem.service brainstem
            print_service_row robot-fastlio2.service slam
            print_service_row robot-localizer.service localizer
            print_service_row robot-super-lio.service super_lio
            print_service_row robot-super-lio-relocation.service super_lio_relocation
            print_service_row lingtu.service lingtu
            warn_legacy_services ;;
        restart)
            local target="${2:-}"
            case "$target" in
                all)    svc_restart_robot_stack ;;
                lidar)  svc_restart_lidar_chain ;;
                localization|localization_chain|slam_chain|loc)
                        svc_restart_localization_chain ;;
                *)
                        local unit
                        unit=$(svc_unit "$target") || { echo "Usage: lingtu svc restart [lidar|localization|slam|localizer|super_lio|super_lio_relocation|lingtu|camera|brainstem|all]"; exit 1; }
                        sudo systemctl restart "$unit"
                        echo "$unit restarted" ;;
            esac ;;
        stop)
            local target="${2:-all}"
            case "$target" in
                all) sudo systemctl stop lingtu.service robot-super-lio-relocation.service robot-super-lio.service robot-localizer.service robot-fastlio2.service robot-lidar.service
                     echo "robot LiDAR + SLAM + localizer + Super-LIO + relocation + lingtu stopped" ;;
                *)
                    local unit
                    unit=$(svc_unit "$target") || { echo "Usage: lingtu svc stop [lidar|slam|localizer|super_lio|super_lio_relocation|lingtu|camera|brainstem|all]"; exit 1; }
                    sudo systemctl stop "$unit"; echo "$unit stopped" ;;
            esac ;;
        *) echo "Usage: lingtu svc [status|restart <target>|stop <target>]"; exit 1 ;;
    esac
}

# ── Subcommand: log ──
doctor_usage() {
    echo "Usage: lingtu doctor [--non-motion] [--json] [--strict] [--realtime] [--require-camera]"
}

source_robot_env() {
    set +u
    [ -f /opt/ros/humble/setup.bash ] && source /opt/ros/humble/setup.bash >/dev/null 2>&1
    [ -f /opt/lingtu/current/install/setup.bash ] && source /opt/lingtu/current/install/setup.bash >/dev/null 2>&1
    set -u
}

cmd_doctor_json() {
    local strict="${1:-0}" non_motion="${2:-0}" realtime="${3:-0}" require_camera="${4:-0}"
    python3 - "$GW" "$strict" "$non_motion" "$realtime" "$require_camera" <<'PY'
import asyncio
import glob
import json
import os
import subprocess
import sys
import time
import urllib.error
import urllib.request
from collections import Counter
from urllib.parse import urlparse

gw = sys.argv[1].rstrip("/")
strict = sys.argv[2] == "1"
non_motion = sys.argv[3] == "1"
realtime = sys.argv[4] == "1"
require_camera = sys.argv[5] == "1"
checks = []


def env_float(name, default):
    raw = os.environ.get(name)
    if raw in (None, ""):
        return float(default)
    try:
        return float(raw)
    except (TypeError, ValueError):
        return float(default)


def camera_check_status(ok):
    if ok:
        return "pass"
    return "fail" if require_camera else "warn"


def camera_check_level():
    return "p0" if require_camera else "p1"


MIN_SLAM_HZ = env_float("LINGTU_DOCTOR_MIN_SLAM_HZ", 1.0)
MIN_MAP_POINTS = env_float("LINGTU_DOCTOR_MIN_MAP_POINTS", 1.0)
MAX_ODOM_AGE_MS = env_float("LINGTU_DOCTOR_MAX_ODOM_AGE_MS", 1500.0)
MAX_LOC_DIAG_AGE_MS = env_float("LINGTU_DOCTOR_MAX_LOC_DIAG_AGE_MS", 3000.0)
MAX_LOCALIZER_HEALTH_AGE_MS = env_float("LINGTU_DOCTOR_MAX_LOCALIZER_HEALTH_AGE_MS", 3000.0)
MAX_CLOUD_AGE_MS = env_float("LINGTU_DOCTOR_MAX_CLOUD_AGE_MS", 5000.0)
MIN_LOCALIZATION_CONFIDENCE = env_float("LINGTU_DOCTOR_MIN_LOCALIZATION_CONFIDENCE", 0.5)
PLAN_PREVIEW_OFFSET_M = env_float("LINGTU_DOCTOR_PLAN_PREVIEW_OFFSET_M", 0.2)
REALTIME_TIMEOUT_S = env_float("LINGTU_DOCTOR_REALTIME_TIMEOUT_S", 6.0)
MAX_DATAFLOW_AVG_MS = env_float("LINGTU_DOCTOR_MAX_DATAFLOW_AVG_MS", 150.0)
MAX_DATAFLOW_P95_MS = env_float("LINGTU_DOCTOR_MAX_DATAFLOW_P95_MS", 250.0)
MAX_DATAFLOW_MAX_MS = env_float("LINGTU_DOCTOR_MAX_DATAFLOW_MAX_MS", 1000.0)
MAX_DATAFLOW_DROP_RATIO = env_float("LINGTU_DOCTOR_MAX_DATAFLOW_DROP_RATIO", 0.75)
DATA_NAV_BLOCKERS = {
    "odometry_missing",
    "localization_degraded",
    "localization_lost",
    "localization_relocalizing",
    "localization_initializing",
    "pose_stale",
}
MOVING_NAV_STATES = {"EXECUTING", "NAVIGATING", "PLANNING", "EXPLORING", "RECOVERY", "RUNNING"}


def resolve_tool(args):
    if not args:
        return args
    overrides = {
        "ros2": os.environ.get("LINGTU_ROS2_BIN"),
        "systemctl": os.environ.get("LINGTU_SYSTEMCTL_BIN"),
        "journalctl": os.environ.get("LINGTU_JOURNALCTL_BIN"),
        "ip": os.environ.get("LINGTU_IP_BIN"),
    }
    override = overrides.get(args[0])
    if override:
        return [override, *args[1:]]
    return args


def run(args, timeout=3):
    try:
        proc = subprocess.run(
            resolve_tool(args),
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            text=True,
            encoding="utf-8",
            errors="replace",
            timeout=timeout,
            check=False,
        )
        return proc.returncode, proc.stdout.strip(), proc.stderr.strip()
    except FileNotFoundError:
        return 127, "", "not found"
    except subprocess.TimeoutExpired as exc:
        return 124, (exc.stdout or "").strip(), "timeout"


def http_json(path, timeout=3, method="GET", payload=None):
    url = path if path.startswith("http") else f"{gw}{path}"
    try:
        headers = {"Accept": "application/json"}
        data = None
        if payload is not None:
            data = json.dumps(payload, separators=(",", ":")).encode("utf-8")
            headers["Content-Type"] = "application/json"
        req = urllib.request.Request(url, data=data, headers=headers, method=method)
        with urllib.request.urlopen(req, timeout=timeout) as resp:
            body = resp.read(2_000_000).decode("utf-8", "replace")
            code = resp.getcode()
    except urllib.error.HTTPError as exc:
        body = exc.read(2_000_000).decode("utf-8", "replace")
        code = exc.code
    except Exception as exc:
        return None, None, str(exc)
    try:
        return code, json.loads(body or "{}"), None
    except Exception as exc:
        return code, None, f"invalid json: {exc}"


def as_float(value):
    try:
        if value in (None, "", "unknown", "null"):
            return None
        return float(value)
    except (TypeError, ValueError):
        return None


def as_bool(value):
    if isinstance(value, bool):
        return value
    if isinstance(value, str):
        return value.strip().lower() in {"1", "true", "yes", "ok", "ready", "active"}
    return bool(value)


def command_source_name(control):
    source = control.get("active_cmd_source")
    if source in (None, "", "unknown"):
        source = control.get("active_source")
    if isinstance(source, dict):
        source = source.get("name") or source.get("source") or source.get("owner") or "none"
    if source in (None, ""):
        return "none"
    return str(source)


def navigation_state_name(nav):
    mission = nav.get("mission") if isinstance(nav, dict) else {}
    if not isinstance(mission, dict):
        mission = {}
    return str(nav.get("state") or mission.get("state") or "unknown")


def navigation_state_is_idle(state):
    return str(state or "").upper() not in MOVING_NAV_STATES


def check_age(payload, key, max_age_ms, blockers):
    value = as_float(payload.get(key))
    if value is None:
        return None
    if value > max_age_ms:
        blockers.append(f"{key}>{max_age_ms:g}ms")
    return value


def module_detail(ready_payload, module_name):
    modules = ready_payload.get("modules") or {}
    module = modules.get(module_name) or {}
    if not isinstance(module, dict):
        return {}
    detail = module.get("detail")
    return detail if isinstance(detail, dict) else {}


def port_in_stats(ready_payload, module_name, port_name):
    detail = module_detail(ready_payload, module_name)
    ports_in = detail.get("ports_in") or {}
    port = ports_in.get(port_name) or {}
    return port if isinstance(port, dict) else {}


def add_dataflow_pressure_check(ready_payload, module_name, port_name, level="p1"):
    if not module_detail(ready_payload, module_name):
        return
    port = port_in_stats(ready_payload, module_name, port_name)
    if not port:
        add(
            f"dataflow.{module_name}.{port_name}",
            "warn",
            level,
            f"{module_name}.{port_name} stats are unavailable",
            {},
        )
        return
    latency = port.get("latency") if isinstance(port.get("latency"), dict) else {}
    avg_ms = as_float(port.get("avg_callback_ms"))
    max_ms = as_float(port.get("max_callback_ms"))
    p95_ms = as_float(latency.get("p95_ms"))
    p99_ms = as_float(latency.get("p99_ms"))
    rate_hz = as_float(port.get("rate_hz"))
    deliver_count = as_float(port.get("deliver_count")) or 0.0
    drop_count = as_float(port.get("drop_count")) or 0.0
    total_count = deliver_count + drop_count
    drop_ratio = (drop_count / total_count) if total_count > 0 else 0.0
    pressure = []
    if avg_ms is not None and avg_ms > MAX_DATAFLOW_AVG_MS:
        pressure.append(f"avg_callback_ms>{MAX_DATAFLOW_AVG_MS:g}")
    if p95_ms is not None and p95_ms > MAX_DATAFLOW_P95_MS:
        pressure.append(f"p95_ms>{MAX_DATAFLOW_P95_MS:g}")
    if max_ms is not None and max_ms > MAX_DATAFLOW_MAX_MS:
        pressure.append(f"max_callback_ms>{MAX_DATAFLOW_MAX_MS:g}")
    if total_count >= 100 and drop_ratio > MAX_DATAFLOW_DROP_RATIO:
        pressure.append(f"drop_ratio>{MAX_DATAFLOW_DROP_RATIO:g}")
    add(
        f"dataflow.{module_name}.{port_name}",
        "warn" if pressure else "pass",
        level,
        f"{module_name}.{port_name} callback pressure detected"
        if pressure
        else f"{module_name}.{port_name} callback pressure within thresholds",
        {
            "rate_hz": rate_hz,
            "avg_callback_ms": avg_ms,
            "p95_ms": p95_ms,
            "p99_ms": p99_ms,
            "max_callback_ms": max_ms,
            "deliver_count": deliver_count,
            "drop_count": drop_count,
            "drop_ratio": round(drop_ratio, 4),
            "thresholds": {
                "max_avg_ms": MAX_DATAFLOW_AVG_MS,
                "max_p95_ms": MAX_DATAFLOW_P95_MS,
                "max_max_ms": MAX_DATAFLOW_MAX_MS,
                "max_drop_ratio": MAX_DATAFLOW_DROP_RATIO,
            },
            "pressure": pressure,
        },
    )


def sse_smoke(timeout_s):
    url = f"{gw}/api/v1/events"
    started = time.time()
    try:
        req = urllib.request.Request(url, headers={"Accept": "text/event-stream"})
        with urllib.request.urlopen(req, timeout=timeout_s) as resp:
            lines = []
            while time.time() - started < timeout_s and len(lines) < 12:
                raw = resp.readline()
                if not raw:
                    break
                line = raw.decode("utf-8", "replace").strip()
                if line:
                    lines.append(line[:200])
                if line.startswith("data:"):
                    return True, {"lines": lines, "first_data": line[:200]}
            return False, {"lines": lines, "error": "no data line before timeout"}
    except Exception as exc:
        return False, {"error": repr(exc)}


async def _ws_once(path, expected_prefix, timeout_s):
    try:
        import websockets
    except Exception as exc:
        return False, {"error": f"websockets unavailable: {exc}"}
    parsed = urlparse(gw)
    scheme = "wss" if parsed.scheme == "https" else "ws"
    url = f"{scheme}://{parsed.netloc}{path}"
    try:
        async with websockets.connect(url, max_size=8_000_000) as ws:
            msg = await asyncio.wait_for(ws.recv(), timeout=timeout_s)
            raw = msg.encode("utf-8") if isinstance(msg, str) else bytes(msg)
            prefix_ok = raw.startswith(expected_prefix)
            return prefix_ok, {"url": url, "bytes": len(raw), "prefix": raw[:3].hex()}
    except Exception as exc:
        return False, {"url": url, "error": repr(exc)}


def ws_smoke(path, expected_prefix, timeout_s):
    return asyncio.run(_ws_once(path, expected_prefix, timeout_s))


def topic_counts(topic):
    rc, out, err = run(["ros2", "topic", "info", topic], timeout=3)
    pubs = 0
    subs = 0
    if rc == 127:
        return None, None, "ros2 not found"
    if rc != 0 and not out:
        return 0, 0, err or f"ros2 topic info failed rc={rc}"
    for line in out.splitlines():
        if "Publisher count:" in line:
            try:
                pubs = int(line.rsplit(":", 1)[1].strip())
            except ValueError:
                pubs = 0
        if "Subscription count:" in line:
            try:
                subs = int(line.rsplit(":", 1)[1].strip())
            except ValueError:
                subs = 0
    return pubs, subs, None


def parse_camera_device_status(text):
    fields = {}
    parsers = {
        "device_online": "bool",
        "connection_type": "str",
        "color_frame_rate_cur": "float",
        "depth_frame_rate_cur": "float",
        "color_frame_rate_target": "float",
        "depth_frame_rate_target": "float",
    }
    for line in text.splitlines():
        if ":" not in line:
            continue
        key, raw = line.split(":", 1)
        key = key.strip()
        if key not in parsers:
            continue
        value = raw.strip().strip("'\"")
        if parsers[key] == "bool":
            lowered = value.lower()
            if lowered in {"true", "false"}:
                fields[key] = lowered == "true"
            else:
                fields[key] = value
        elif parsers[key] == "float":
            try:
                fields[key] = float(value)
            except ValueError:
                fields[key] = value
        else:
            fields[key] = value
    return fields


def camera_device_status_once():
    rc, out, err = run(["ros2", "topic", "echo", "/camera/device_status", "--once"], timeout=6)
    if rc == 127:
        return None, "ros2 not found"
    if rc != 0 and not out:
        return None, err or f"ros2 topic echo failed rc={rc}"
    status = parse_camera_device_status(out)
    if not status:
        return None, err or "device_status sample did not contain expected fields"
    return status, None


def latest_livox_sdk_event():
    rc, out, err = run(["journalctl", "-u", "robot-lidar.service", "-b", "-n", "200", "--no-pager"], timeout=5)
    if rc == 127:
        return "unknown", {"error": "journalctl not found"}
    if rc != 0 and not out:
        return "unknown", {"returncode": rc, "stderr": err}
    latest = None
    for line in out.splitlines():
        lower = line.lower()
        if "init lds lidar success" in lower:
            latest = ("success", line[-500:])
        elif (
            "init lds lidar fail" in lower
            or "failed to init livox lidar sdk" in lower
            or "bind failed" in lower
        ):
            latest = ("fail", line[-500:])
    if latest is None:
        return "unknown", {"returncode": rc, "stderr": err, "searched_lines": len(out.splitlines())}
    status, line = latest
    return status, {"returncode": rc, "latest_event": line}


def netdev_state(name):
    base = f"/sys/class/net/{name}"
    evidence = {"interface": name}
    for field in ("operstate", "carrier"):
        path = os.path.join(base, field)
        try:
            with open(path, "r", encoding="utf-8") as fh:
                evidence[field] = fh.read().strip()
        except OSError as exc:
            evidence[f"{field}_error"] = str(exc)
    rc, out, err = run(["ip", "-br", "addr", "show", name], timeout=2)
    evidence["ip_br"] = out.strip()
    if err:
        evidence["ip_error"] = err
    return evidence


def add(check_id, status, level, message, evidence=None):
    checks.append(
        {
            "id": check_id,
            "status": status,
            "level": level,
            "message": message,
            "evidence": evidence or {},
        }
    )


