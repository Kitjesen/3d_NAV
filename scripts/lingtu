# -- Subcommand: evidence --
cmd_evidence_usage() {
    echo "Usage: lingtu evidence [--duration SEC] [--min-motion-m M] [--min-cmd-vel-norm V] [--json] [--json-out PATH] [--expected-command-subscriber NAME] [--no-validate]"
    echo "Collect read-only real S100P runtime evidence for topics, frames, data flow, and command boundary."
    echo "Requires an active real run publishing /nav/odometry, /nav/map_cloud, /nav/localization_health, and /nav/localization_quality."
}

cmd_evidence() {
    local duration="20"
    local out_path=""
    local json_flag=0
    local no_validate=0
    local repo_root
    local python_bin
    local min_motion_m=""
    local min_cmd_vel_norm=""
    local -a expected_subscribers=()

    while [ "$#" -gt 0 ]; do
        case "$1" in
            --duration|--duration-sec)
                [ -n "${2:-}" ] || { cmd_evidence_usage; return 1; }
                duration="$2"
                shift 2 ;;
            --duration=*|--duration-sec=*)
                duration="${1#*=}"
                shift ;;
            --json)
                json_flag=1
                shift ;;
            --min-motion-m)
                [ -n "${2:-}" ] || { cmd_evidence_usage; return 1; }
                min_motion_m="$2"
                shift 2 ;;
            --min-motion-m=*)
                min_motion_m="${1#*=}"
                shift ;;
            --min-cmd-vel-norm)
                [ -n "${2:-}" ] || { cmd_evidence_usage; return 1; }
                min_cmd_vel_norm="$2"
                shift 2 ;;
            --min-cmd-vel-norm=*)
                min_cmd_vel_norm="${1#*=}"
                shift ;;
            --json-out)
                [ -n "${2:-}" ] || { cmd_evidence_usage; return 1; }
                out_path="$2"
                shift 2 ;;
            --json-out=*)
                out_path="${1#*=}"
                shift ;;
            --expected-command-subscriber)
                [ -n "${2:-}" ] || { cmd_evidence_usage; return 1; }
                expected_subscribers+=("$2")
                shift 2 ;;
            --expected-command-subscriber=*)
                expected_subscribers+=("${1#*=}")
                shift ;;
            --no-validate)
                no_validate=1
                shift ;;
            -h|--help)
                cmd_evidence_usage
                return 0 ;;
            *)
                cmd_evidence_usage
                return 1 ;;
        esac
    done

    case "$duration" in
        ''|*[!0-9.]*)
            echo "duration must be a numeric number of seconds" >&2
            return 1 ;;
    esac

    repo_root="$(lingtu_repo_root)"
    python_bin="$(lingtu_python)"
    if [ -z "$out_path" ]; then
        out_path="$repo_root/artifacts/real_s100p_runtime/report.json"
    fi
    mkdir -p "$(dirname "$out_path")"

    local -a cmd=(
        "$python_bin" "$repo_root/lingtu.py" real-runtime-evidence
        --duration-sec "$duration"
        --json-out "$out_path"
    )
    local subscriber
    for subscriber in "${expected_subscribers[@]}"; do
        cmd+=(--expected-command-subscriber "$subscriber")
    done
    [ -n "$min_motion_m" ] && cmd+=(--min-motion-m "$min_motion_m")
    [ -n "$min_cmd_vel_norm" ] && cmd+=(--min-cmd-vel-norm "$min_cmd_vel_norm")
    [ "$json_flag" = "1" ] && cmd+=(--json)
    [ "$no_validate" = "1" ] && cmd+=(--no-validate)

    echo "Collecting read-only real runtime evidence..." >&2
    echo "Report: $out_path" >&2
    "${cmd[@]}"
}

# -- Subcommand: health --
cmd_health() {
    curl -s "$GW/api/v1/health" 2>/dev/null | python3 -m json.tool
}

# ── Top-level dispatch ──
case "${1:-status}" in
    status|s)       cmd_status ;;
    watch|w)        shift; cmd_watch "$@" ;;
    map|m)          shift; cmd_map   "$@" ;;
    nav|n)          shift; cmd_nav   "$@" ;;
    svc|service)    shift; cmd_svc   "$@" ;;
    doctor|diag)    shift; cmd_doctor "$@" ;;
    soak|field-soak|readiness-soak) shift; cmd_soak "$@" ;;
    slamcheck|slam-check) shift; cmd_slamcheck "$@" ;;
    slamcompare|slam-compare|super-lio-compare|super_lio_compare|superlio-compare) shift; cmd_slamcompare "$@" ;;
    plan-preview|planpreview|preview-plan) shift; cmd_plan_preview "$@" ;;
    routecheck|route-check|route-preflight|super-lio-routecheck|super_lio_routecheck) shift; cmd_routecheck "$@" ;;
    routecompare|route-compare|super-lio-routecompare|super_lio_routecompare) shift; cmd_routecompare "$@" ;;
    super-lio-smoke|super_lio_smoke|superlio-smoke) shift; cmd_slamcheck super_lio "$@" ;;
    super-lio-relocation-smoke|super_lio_relocation_smoke|super-lio-reloc-smoke|super_lio_reloc_smoke) shift; cmd_slamcheck super_lio_relocation "$@" ;;
    log|l)          shift; cmd_log   "$@" ;;
    contract|runtime-contract) shift; cmd_runtime_contract "$@" ;;
    spec|runtime-spec) shift; cmd_runtime_spec "$@" ;;
    audit|runtime-audit) shift; cmd_runtime_audit "$@" ;;
    dataflow|flow) shift; cmd_dataflow "$@" ;;
    gateway-runtime-acceptance|gateway-acceptance|gw-accept) shift; cmd_gateway_runtime_acceptance "$@" ;;
    field-check|field-acceptance|accept) shift; cmd_field_check "$@" ;;
    inspection-check|inspection-acceptance|inspect-accept) shift; cmd_inspection_check "$@" ;;
    saved-map-artifact-gate|map-gate) shift; cmd_saved_map_artifact_gate "$@" ;;
    evidence|runtime-evidence|real-runtime-evidence) shift; cmd_evidence "$@" ;;
    health|h)       cmd_health ;;
    help|-h|--help)
        sed -n '2,/^set -u/p' "$0" | sed 's/^# //;s/^#//' ;;
    *)
        echo "Unknown command: $1"
        echo "Run 'lingtu help' for usage."
        exit 1 ;;
esac
