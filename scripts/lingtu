        continue
    if pubs is None:
        add(f"topic.{topic}", "fail", "p0", f"could not inspect {topic}", {"error": err})
    elif pubs == 0:
        add(f"topic.{topic}", "fail", "p0", f"{topic} has no publishers", {"publishers": pubs, "subscribers": subs, "error": err})
    elif topic in {"/nav/lidar_scan", "/nav/imu", "/nav/odometry"} and pubs > 1:
        add(f"topic.{topic}", "fail", "p0", f"{topic} has duplicate publishers", {"publishers": pubs, "subscribers": subs})
    else:
        add(f"topic.{topic}", "pass", "p0", f"{topic} has publishers", {"publishers": pubs, "subscribers": subs})

