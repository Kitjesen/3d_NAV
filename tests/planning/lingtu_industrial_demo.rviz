Panels:
  - Class: rviz_common/Displays
    Help Height: 0
    Name: Displays
    Property Tree Widget:
      Expanded: ~
      Splitter Ratio: 0.5
    Tree Height: 760
  - Class: rviz_common/Views
    Name: Views

Visualization Manager:
  Class: ""
  Displays:
    - Class: rviz_default_plugins/Grid
      Name: GroundGrid
      Enabled: true
      Cell Size: 1
      Color: 80; 80; 80
      Plane Cell Count: 48
      Plane: XY

    - Class: rviz_default_plugins/Map
      Name: ExplorationOccupancyGrid
      Enabled: true
      Topic:
        Value: /nav/exploration_grid
        Depth: 1
      Alpha: 0.65
      Color Scheme: map
      Draw Behind: false
      Use Timestamp: false

    - Class: rviz_default_plugins/PointCloud2
      Name: LiveRegisteredCloud
      Enabled: true
      Topic: /nav/registered_cloud
      Alpha: 0.35
      Autocompute Intensity Bounds: true
      Color Transformer: FlatColor
      Color: 0; 220; 255
      Queue Size: 20
      Size (Pixels): 1
      Size (m): 0.018
      Style: Points
      Position Transformer: XYZ
      Unreliable: true
      Use Fixed Frame: true

    - Class: rviz_default_plugins/PointCloud2
      Name: LiveOdomMapCloud
      Enabled: true
      Topic: /nav/map_cloud
      Alpha: 0.28
      Autocompute Intensity Bounds: true
      Color Transformer: FlatColor
      Color: 0; 255; 120
      Queue Size: 20
      Size (Pixels): 1
      Size (m): 0.015
      Style: Points
      Position Transformer: XYZ
      Unreliable: true
      Use Fixed Frame: true

    - Class: rviz_default_plugins/PointCloud2
      Name: DebugCumulativeMapCloud
      Enabled: false
      Topic: /nav/cumulative_map_cloud
      Alpha: 0.55
      Autocompute Intensity Bounds: true
      Color Transformer: FlatColor
      Color: 255; 220; 80
      Queue Size: 10
      Size (Pixels): 1
      Size (m): 0.025
      Style: Points
      Position Transformer: XYZ
      Unreliable: true
      Use Fixed Frame: true

    - Class: rviz_default_plugins/Path
      Name: GlobalPath
      Enabled: true
      Topic:
        Value: /nav/global_path
        Depth: 5
      Color: 80; 170; 255
      Line Style: Lines
      Line Width: 0.045

    - Class: rviz_default_plugins/Path
      Name: LocalPath
      Enabled: true
      Topic:
        Value: /nav/local_path
        Depth: 5
      Color: 0; 220; 120
      Line Style: Lines
      Line Width: 0.045

    - Class: rviz_default_plugins/Odometry
      Name: RobotOdometry
      Enabled: true
      Topic:
        Value: /nav/odometry
        Depth: 5
      Shape: Arrow
      Color: 255; 120; 0
      Scale: 0.35

    - Class: rviz_default_plugins/Pose
      Name: GoalPose
      Enabled: true
      Topic:
        Value: /nav/goal_pose
        Depth: 1
      Color: 255; 60; 60
      Shaft Length: 0.45
      Head Length: 0.18
      Head Radius: 0.10

    - Class: rviz_default_plugins/Marker
      Name: RobotMarker
      Enabled: true
      Topic:
        Value: /nav/robot_marker
        Depth: 5

    - Class: rviz_default_plugins/TF
      Name: TF
      Enabled: true

  Enabled: true
  Global Options:
    Background Color: 20; 24; 30
    Fixed Frame: odom
    Frame Rate: 30
  Name: root

  Tools:
    - Class: rviz_default_plugins/Interact
      Hide Inactive Objects: true
    - Class: rviz_default_plugins/MoveCamera
    - Class: rviz_default_plugins/Select
    - Class: rviz_default_plugins/FocusCamera
    - Class: rviz_default_plugins/Measure
      Line color: 128; 128; 0
    - Class: rviz_default_plugins/SetGoal
      Topic:
        Value: /nav/goal_pose
    - Class: rviz_default_plugins/PublishPoint
      Topic:
        Value: /clicked_point
        QoS Profile: default

  Views:
    Current:
      Class: rviz_default_plugins/Orbit
      Name: Industrial Demo View
      Distance: 22
      Pitch: 1.05
      Yaw: 1.5708
      Focal Point:
        X: 7
        Y: 0
        Z: 1
      Focal Shape Fixed Size: true
      Focal Shape Size: 0.05
      Target Frame: odom

Window Geometry:
  Displays:
    collapsed: false
  Height: 980
  Hide Left Dock: false
  QMainWindow State: ""
  Views:
    collapsed: false
  Width: 1320
  X: 760
  Y: 40
