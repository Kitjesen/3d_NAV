Panels:
  - Class: rviz_common/Displays
    Help Height: 0
    Name: Displays
    Property Tree Widget:
      Expanded: ~
      Splitter Ratio: 0.48
    Tree Height: 780
  - Class: rviz_common/Views
    Name: Views

Visualization Manager:
  Class: ""
  Displays:
    - Class: rviz_default_plugins/Grid
      Name: GroundGrid
      Enabled: true
      Cell Size: 1
      Color: 80; 80; 80
      Plane Cell Count: 60
      Plane: XY

    - Class: rviz_default_plugins/Map
      Name: LingTuExplorationGrid
      Enabled: true
      Topic:
        Value: /nav/exploration_grid
        Depth: 1
      Alpha: 0.62
      Color Scheme: map
      Draw Behind: true
      Use Timestamp: false

    - Class: rviz_default_plugins/PointCloud2
      Name: FastLIORegisteredCloud
      Enabled: false
      Topic: /cloud_registered
      Alpha: 0.18
      Autocompute Intensity Bounds: true
      Color Transformer: FlatColor
      Color: 80; 160; 255
      Queue Size: 10
      Size (Pixels): 1
      Size (m): 0.012
      Style: Points
      Position Transformer: XYZ
      Unreliable: true
      Use Fixed Frame: true

    - Class: rviz_default_plugins/PointCloud2
      Name: FastLIOMapCloud
      Enabled: false
      Topic: /cloud_map
      Alpha: 0.16
      Autocompute Intensity Bounds: true
      Color Transformer: FlatColor
      Color: 190; 190; 190
      Queue Size: 10
      Size (Pixels): 1
      Size (m): 0.01
      Style: Points
      Position Transformer: XYZ
      Unreliable: true
      Use Fixed Frame: true

    - Class: rviz_default_plugins/PointCloud2
      Name: LingTuRegisteredCloud
      Enabled: true
      Topic: /nav/registered_cloud
      Alpha: 0.38
      Autocompute Intensity Bounds: true
      Color Transformer: FlatColor
      Color: 0; 220; 255
      Queue Size: 20
      Size (Pixels): 1
      Size (m): 0.016
      Style: Points
      Position Transformer: XYZ
      Unreliable: true
      Use Fixed Frame: true

    - Class: rviz_default_plugins/PointCloud2
      Name: LingTuMapCloud
      Enabled: true
      Topic: /nav/map_cloud
      Alpha: 0.32
      Autocompute Intensity Bounds: true
      Color Transformer: FlatColor
      Color: 0; 255; 120
      Queue Size: 20
      Size (Pixels): 1
      Size (m): 0.014
      Style: Points
      Position Transformer: XYZ
      Unreliable: true
      Use Fixed Frame: true

    - Class: rviz_default_plugins/Path
      Name: GlobalPath
      Enabled: true
      Topic:
        Value: /nav/global_path
        Depth: 5
      Color: 80; 170; 255
      Line Style: Lines
      Line Width: 0.06

    - Class: rviz_default_plugins/Path
      Name: LocalPath
      Enabled: true
      Topic:
        Value: /nav/local_path
        Depth: 5
      Color: 0; 230; 120
      Line Style: Lines
      Line Width: 0.05

    - Class: rviz_default_plugins/Odometry
      Name: RobotOdometry
      Enabled: true
      Topic:
        Value: /nav/odometry
        Depth: 20
      Shape: Arrow
      Color: 255; 120; 0
      Scale: 0.45

    - Class: rviz_default_plugins/TF
      Name: TF
      Enabled: true

  Enabled: true
  Global Options:
    Background Color: 18; 22; 28
    Fixed Frame: odom
    Frame Rate: 30
  Name: root

  Tools:
    - Class: rviz_default_plugins/Interact
      Hide Inactive Objects: true
    - Class: rviz_default_plugins/MoveCamera
    - Class: rviz_default_plugins/Select
    - Class: rviz_default_plugins/FocusCamera
    - Class: rviz_default_plugins/Measure
      Line color: 128; 128; 0
    - Class: rviz_default_plugins/SetGoal
      Topic:
        Value: /nav/goal_pose
    - Class: rviz_default_plugins/PublishPoint
      Topic:
        Value: /clicked_point
        QoS Profile: default

  Views:
    Current:
      Class: rviz_default_plugins/Orbit
      Name: MuJoCo Fast-LIO Live
      Distance: 24
      Pitch: 0.95
      Yaw: 1.5708
      Focal Point:
        X: 6
        Y: 0
        Z: 1
      Focal Shape Fixed Size: true
      Focal Shape Size: 0.05
      Target Frame: odom

Window Geometry:
  Displays:
    collapsed: false
  Height: 980
  Hide Left Dock: false
  QMainWindow State: ""
  Views:
    collapsed: false
  Width: 1440
  X: 720
  Y: 35
