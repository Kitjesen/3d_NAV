Panels:
  - Class: rviz_common/Displays
    Help Height: 0
    Name: Displays
    Property Tree Widget:
      Expanded: ~
      Splitter Ratio: 0.5
    Tree Height: 700
  - Class: rviz_common/Views
    Name: Views

Visualization Manager:
  Class: ""
  Displays:
    - Class: rviz_default_plugins/Grid
      Name: Grid
      Enabled: true
      Cell Size: 1
      Color: 100; 100; 100
      Plane Cell Count: 30
      Plane: XY

    - Class: rviz_default_plugins/PointCloud2
      Name: LiveOdomCloud
      Enabled: true
      Topic: /nav/map_cloud
      Alpha: 1
      Autocompute Intensity Bounds: true
      Color Transformer: FlatColor
      Color: 0; 255; 120
      Queue Size: 100
      Size (Pixels): 2
      Size (m): 0.03
      Style: Points
      Position Transformer: XYZ
      Unreliable: true
      Use Fixed Frame: true
      Value: true

    - Class: rviz_default_plugins/PointCloud2
      Name: RegisteredCloud
      Enabled: false
      Topic: /nav/registered_cloud
      Alpha: 0.45
      Autocompute Intensity Bounds: true
      Color Transformer: FlatColor
      Color: 0; 220; 255
      Queue Size: 100
      Size (Pixels): 2
      Size (m): 0.025
      Style: Points
      Position Transformer: XYZ
      Unreliable: true
      Use Fixed Frame: true
      Value: false

    - Class: rviz_default_plugins/Path
      Name: GlobalPath
      Enabled: true
      Topic:
        Value: /nav/global_path
        Depth: 5
      Color: 255; 200; 0
      Line Style: Lines
      Line Width: 0.08

    - Class: rviz_default_plugins/Path
      Name: LocalPath
      Enabled: true
      Topic:
        Value: /nav/local_path
        Depth: 5
      Color: 0; 220; 80
      Line Style: Lines
      Line Width: 0.05

    - Class: rviz_default_plugins/Odometry
      Name: RobotOdometry
      Enabled: true
      Topic:
        Value: /nav/odometry
        Depth: 5
      Shape: Arrow
      Color: 0; 100; 255
      Scale: 0.5

    - Class: rviz_default_plugins/RobotModel
      Name: RobotModel
      Enabled: false
      Description Topic:
        Value: /robot_description
        Durability Policy: Transient Local
      Value: false

    - Class: rviz_default_plugins/Pose
      Name: GoalPose
      Enabled: true
      Topic:
        Value: /nav/goal_pose
        Depth: 5
      Color: 255; 60; 60
      Shaft Length: 1.0
      Head Length: 0.4
      Head Radius: 0.2

    - Class: rviz_default_plugins/PointStamped
      Name: ClickedPoint
      Enabled: true
      Topic:
        Value: /clicked_point
        Depth: 5
      Color: 255; 200; 0
      Radius: 0.2

    - Class: rviz_default_plugins/Marker
      Name: RobotMarker
      Enabled: true
      Topic:
        Value: /nav/robot_marker
        Depth: 5

    - Class: rviz_default_plugins/TF
      Name: TF
      Enabled: true

  Enabled: true
  Global Options:
    Background Color: 25; 25; 35
    Fixed Frame: odom
    Frame Rate: 30
  Name: root

  Tools:
    - Class: rviz_default_plugins/Interact
      Hide Inactive Objects: true
    - Class: rviz_default_plugins/MoveCamera
    - Class: rviz_default_plugins/Select
    - Class: rviz_default_plugins/FocusCamera
    - Class: rviz_default_plugins/Measure
      Line color: 128; 128; 0
    - Class: rviz_default_plugins/SetInitialPose
      Topic:
        Value: /initialpose
    - Class: rviz_default_plugins/SetGoal
      Topic:
        Value: /nav/goal_pose
    - Class: rviz_default_plugins/PublishPoint
      Topic:
        Value: /clicked_point
        QoS Profile: default

  Views:
    Current:
      Class: rviz_default_plugins/Orbit
      Name: 3D View
      Distance: 12
      Pitch: 0.45
      Yaw: 1.2
      Focal Point:
        X: 0
        Y: 0
        Z: 1
      Focal Shape Fixed Size: true
      Focal Shape Size: 0.05
      Target Frame: odom

Window Geometry:
  Displays:
    collapsed: false
  Height: 900
  Hide Left Dock: false
  QMainWindow State: ""
  Views:
    collapsed: false
  Width: 1050
  X: 850
  Y: 50
