Panels:
  - Class: rviz_common/Displays
    Name: Displays
    Help Height: 0
    Property Tree Widget:
      Expanded:
        - /Global Options1
        - /LingTu Map Cloud1
        - /TARE Strategy Path1
        - /LingTu Local Path1
      Splitter Ratio: 0.52
    Tree Height: 760
  - Class: rviz_common/Views
    Name: Views

Visualization Manager:
  Class: ""
  Displays:
    - Class: rviz_default_plugins/Grid
      Name: Map Grid
      Enabled: true
      Cell Size: 1
      Color: 70; 70; 70
      Plane Cell Count: 80
      Plane: XY

    - Class: rviz_default_plugins/PointCloud2
      Name: LingTu Map Cloud
      Enabled: true
      Topic: /nav/map_cloud
      Alpha: 0.55
      Autocompute Intensity Bounds: true
      Color Transformer: FlatColor
      Color: 95; 150; 220
      Queue Size: 10
      Size (Pixels): 2
      Size (m): 0.035
      Style: Points
      Position Transformer: XYZ
      Unreliable: true
      Use Fixed Frame: true

    - Class: rviz_default_plugins/PointCloud2
      Name: LingTu Local Obstacle Cloud
      Enabled: true
      Topic: /nav/registered_cloud
      Alpha: 0.80
      Autocompute Intensity Bounds: true
      Color Transformer: FlatColor
      Color: 0; 235; 155
      Queue Size: 10
      Size (Pixels): 2
      Size (m): 0.045
      Style: Points
      Position Transformer: XYZ
      Unreliable: true
      Use Fixed Frame: true

    - Class: rviz_default_plugins/PointCloud2
      Name: CMU Terrain Map Ext
      Enabled: true
      Topic: /nav/terrain_map_ext
      Alpha: 0.45
      Autocompute Intensity Bounds: true
      Color Transformer: FlatColor
      Color: 235; 200; 70
      Queue Size: 10
      Size (Pixels): 2
      Size (m): 0.050
      Style: Points
      Position Transformer: XYZ
      Unreliable: true
      Use Fixed Frame: true

    - Class: rviz_default_plugins/Path
      Name: TARE Strategy Path
      Enabled: true
      Topic:
        Value: /exploration/local_path
        Depth: 5
      Color: 90; 240; 90
      Line Style: Billboards
      Line Width: 0.100

    - Class: rviz_default_plugins/Path
      Name: LingTu Global Path
      Enabled: true
      Topic:
        Value: /nav/global_path
        Depth: 5
      Color: 60; 180; 255
      Line Style: Billboards
      Line Width: 0.090

    - Class: rviz_default_plugins/Path
      Name: LingTu Local Path
      Enabled: true
      Topic:
        Value: /nav/local_path
        Depth: 5
      Color: 255; 160; 50
      Line Style: Billboards
      Line Width: 0.120

    - Class: rviz_default_plugins/Odometry
      Name: Robot Odometry
      Enabled: true
      Topic:
        Value: /nav/odometry
        Depth: 10
      Shape: Arrow
      Color: 255; 80; 60
      Scale: 0.45

    - Class: rviz_default_plugins/TF
      Name: TF
      Enabled: true

  Enabled: true
  Global Options:
    Background Color: 24; 26; 30
    Fixed Frame: map
    Frame Rate: 30
  Name: root

  Tools:
    - Class: rviz_default_plugins/Interact
      Hide Inactive Objects: true
    - Class: rviz_default_plugins/MoveCamera
    - Class: rviz_default_plugins/Select
    - Class: rviz_default_plugins/FocusCamera
    - Class: rviz_default_plugins/Measure
      Line color: 128; 128; 0
    - Class: rviz_default_plugins/PublishPoint
      Topic:
        Value: /clicked_point
        QoS Profile: default

  Views:
    Current:
      Class: rviz_default_plugins/Orbit
      Name: CMU Unity LingTu View
      Distance: 42
      Pitch: 1.08
      Yaw: 1.57
      Focal Point:
        X: 4
        Y: 0
        Z: 1
      Focal Shape Fixed Size: true
      Focal Shape Size: 0.05
      Target Frame: map

Window Geometry:
  Displays:
    collapsed: false
  Height: 980
  Hide Left Dock: false
  QMainWindow State: ""
  Views:
    collapsed: false
  Width: 1420
  X: 720
  Y: 40
