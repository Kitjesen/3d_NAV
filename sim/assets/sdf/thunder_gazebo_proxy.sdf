<?xml version="1.0"?>
<sdf version="1.9">
  <model name="thunder">
    <pose>0 0 0.18 0 0 0</pose>

    <link name="base_link">
      <inertial>
        <mass>18.0</mass>
        <inertia>
          <ixx>0.45</ixx>
          <iyy>0.80</iyy>
          <izz>0.95</izz>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyz>0</iyz>
        </inertia>
      </inertial>
      <collision name="body_collision">
        <geometry>
          <box>
            <size>0.72 0.34 0.22</size>
          </box>
        </geometry>
      </collision>
      <visual name="body_visual">
        <geometry>
          <box>
            <size>0.72 0.34 0.22</size>
          </box>
        </geometry>
        <material>
          <ambient>0.08 0.14 0.22 1</ambient>
          <diffuse>0.10 0.20 0.36 1</diffuse>
        </material>
      </visual>
    </link>

    <link name="front_left_wheel">
      <pose>0.26 0.22 -0.06 1.5708 0 0</pose>
      <inertial>
        <mass>0.8</mass>
        <inertia>
          <ixx>0.004</ixx>
          <iyy>0.004</iyy>
          <izz>0.004</izz>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyz>0</iyz>
        </inertia>
      </inertial>
      <collision name="collision">
        <geometry>
          <cylinder>
            <radius>0.09</radius>
            <length>0.06</length>
          </cylinder>
        </geometry>
      </collision>
      <visual name="visual">
        <geometry>
          <cylinder>
            <radius>0.09</radius>
            <length>0.06</length>
          </cylinder>
        </geometry>
      </visual>
    </link>
    <joint name="front_left_wheel_joint" type="revolute">
      <parent>base_link</parent>
      <child>front_left_wheel</child>
      <axis>
        <xyz>0 0 1</xyz>
      </axis>
    </joint>

    <link name="rear_left_wheel">
      <pose>-0.26 0.22 -0.06 1.5708 0 0</pose>
      <inertial>
        <mass>0.8</mass>
        <inertia>
          <ixx>0.004</ixx>
          <iyy>0.004</iyy>
          <izz>0.004</izz>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyz>0</iyz>
        </inertia>
      </inertial>
      <collision name="collision">
        <geometry>
          <cylinder>
            <radius>0.09</radius>
            <length>0.06</length>
          </cylinder>
        </geometry>
      </collision>
      <visual name="visual">
        <geometry>
          <cylinder>
            <radius>0.09</radius>
            <length>0.06</length>
          </cylinder>
        </geometry>
      </visual>
    </link>
    <joint name="rear_left_wheel_joint" type="revolute">
      <parent>base_link</parent>
      <child>rear_left_wheel</child>
      <axis>
        <xyz>0 0 1</xyz>
      </axis>
    </joint>

    <link name="front_right_wheel">
      <pose>0.26 -0.22 -0.06 1.5708 0 0</pose>
      <inertial>
        <mass>0.8</mass>
        <inertia>
          <ixx>0.004</ixx>
          <iyy>0.004</iyy>
          <izz>0.004</izz>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyz>0</iyz>
        </inertia>
      </inertial>
      <collision name="collision">
        <geometry>
          <cylinder>
            <radius>0.09</radius>
            <length>0.06</length>
          </cylinder>
        </geometry>
      </collision>
      <visual name="visual">
        <geometry>
          <cylinder>
            <radius>0.09</radius>
            <length>0.06</length>
          </cylinder>
        </geometry>
      </visual>
    </link>
    <joint name="front_right_wheel_joint" type="revolute">
      <parent>base_link</parent>
      <child>front_right_wheel</child>
      <axis>
        <xyz>0 0 1</xyz>
      </axis>
    </joint>

    <link name="rear_right_wheel">
      <pose>-0.26 -0.22 -0.06 1.5708 0 0</pose>
      <inertial>
        <mass>0.8</mass>
        <inertia>
          <ixx>0.004</ixx>
          <iyy>0.004</iyy>
          <izz>0.004</izz>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyz>0</iyz>
        </inertia>
      </inertial>
      <collision name="collision">
        <geometry>
          <cylinder>
            <radius>0.09</radius>
            <length>0.06</length>
          </cylinder>
        </geometry>
      </collision>
      <visual name="visual">
        <geometry>
          <cylinder>
            <radius>0.09</radius>
            <length>0.06</length>
          </cylinder>
        </geometry>
      </visual>
    </link>
    <joint name="rear_right_wheel_joint" type="revolute">
      <parent>base_link</parent>
      <child>rear_right_wheel</child>
      <axis>
        <xyz>0 0 1</xyz>
      </axis>
    </joint>

    <link name="lidar_link">
      <pose>0.28 0 0.20 0 0 0</pose>
      <sensor name="lidar" type="gpu_lidar">
        <update_rate>10</update_rate>
        <topic>/world/lingtu_gazebo_empty/model/thunder/link/lidar_link/sensor/lidar/scan</topic>
        <ray>
          <scan>
            <horizontal>
              <samples>720</samples>
              <resolution>1</resolution>
              <min_angle>-3.14159</min_angle>
              <max_angle>3.14159</max_angle>
            </horizontal>
            <vertical>
              <samples>32</samples>
              <resolution>1</resolution>
              <min_angle>-0.45</min_angle>
              <max_angle>0.45</max_angle>
            </vertical>
          </scan>
          <range>
            <min>0.2</min>
            <max>30.0</max>
            <resolution>0.02</resolution>
          </range>
        </ray>
        <always_on>true</always_on>
        <visualize>true</visualize>
      </sensor>
    </link>
    <joint name="lidar_joint" type="fixed">
      <parent>base_link</parent>
      <child>lidar_link</child>
    </joint>

    <link name="camera_link">
      <pose>0.36 0 0.22 0 0 0</pose>
      <sensor name="camera" type="camera">
        <update_rate>15</update_rate>
        <topic>/world/lingtu_gazebo_empty/model/thunder/link/camera_link/sensor/camera/image</topic>
        <camera>
          <horizontal_fov>1.047</horizontal_fov>
          <image>
            <width>640</width>
            <height>480</height>
            <format>R8G8B8</format>
          </image>
          <clip>
            <near>0.1</near>
            <far>30.0</far>
          </clip>
        </camera>
        <always_on>true</always_on>
        <visualize>false</visualize>
      </sensor>
      <sensor name="depth_camera" type="depth_camera">
        <update_rate>15</update_rate>
        <topic>/world/lingtu_gazebo_empty/model/thunder/link/camera_link/sensor/depth_camera/image</topic>
        <camera>
          <horizontal_fov>1.047</horizontal_fov>
          <image>
            <width>640</width>
            <height>480</height>
            <format>R_FLOAT32</format>
          </image>
          <clip>
            <near>0.1</near>
            <far>10.0</far>
          </clip>
        </camera>
        <always_on>true</always_on>
        <visualize>false</visualize>
      </sensor>
    </link>
    <joint name="camera_joint" type="fixed">
      <parent>base_link</parent>
      <child>camera_link</child>
    </joint>

    <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
      <left_joint>front_left_wheel_joint</left_joint>
      <left_joint>rear_left_wheel_joint</left_joint>
      <right_joint>front_right_wheel_joint</right_joint>
      <right_joint>rear_right_wheel_joint</right_joint>
      <wheel_separation>0.44</wheel_separation>
      <wheel_radius>0.09</wheel_radius>
      <odom_publish_frequency>50</odom_publish_frequency>
      <topic>/lingtu/gazebo/cmd_vel</topic>
      <odom_topic>/model/thunder/odometry</odom_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>body</child_frame_id>
    </plugin>
  </model>
</sdf>
