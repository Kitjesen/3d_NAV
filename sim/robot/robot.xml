  来源: D:\inovxio\products\quadruped_ws\dog_arm\urdf\dog_arm.urdf
  转换: MuJoCo 3.5.0 from_xml_path + 手动修正
  修正内容:
    1. 添加 freejoint (URDF 转换不生成)
    2. 添加 position actuator + PD 参数 (URDF effort=0)
    3. 添加 visual mesh 资源引用
    4. 恢复 lidar2_Link (导航 LiDAR raycaster 原点)
    5. 设置接触/摩擦参数

  关节布局 (24 joints):
    Arm:  arm_joint_1~6, gripper_left/right
    Legs: fr/fl/rr/rl × (hip, thigh, calf, foot)

  Dart↔MuJoCo 轴向: 全部取反 (SolidWorks vs 电机约定)
============================================================ -->

<mujoco model="nova_dog">
  <compiler angle="radian" meshdir="../assets/meshes/" autolimits="true"/>

  <option gravity="0 0 -9.81" timestep="0.002">
    <flag warmstart="enable"/>
  </option>

  <default>
    <joint damping="1.0" armature="0.01"/>
    <geom friction="1 0.5 0.5" condim="3" conaffinity="1" contype="1"/>
    <motor ctrllimited="true"/>
    <!-- 腿关节 PD 参数: kp×6 + kv=5 (12s稳定，43%@vx=0.5，59%@vx=1.0)
         部署 inferKp=[65,95,120], 训练约 kp×6, kv≈5
         验证: vx=0.5→43%稳定12s; vx=1.0→59%; kp×5/kv=3在7.1s崩溃 -->
    <default class="leg_hip">
      <joint damping="0"/>
      <position kp="390" kv="5"/>
    </default>
    <default class="leg_thigh">
      <joint damping="0"/>
      <position kp="570" kv="5"/>
    </default>
    <default class="leg_calf">
      <joint damping="0"/>
      <position kp="720" kv="5"/>
    </default>
    <default class="leg_foot">
      <joint damping="0"/>
      <position kp="0" kv="1"/>
    </default>
    <default class="arm_joint">
      <joint damping="3.0"/>
      <position kp="200" kv="8"/>
    </default>
  </default>

