<mujoco model="go1 indoor office navigation">
  <!-- Go1 robot model -->
  <include file="../robots/go1_playground/xmls/go1_mjx_feetonly.xml"/>

  <statistic center="4 -2 0.3" extent="6" meansize="0.04"/>

  <visual>
    <headlight diffuse=".7 .7 .7" ambient=".3 .3 .3" specular="0.5 0.5 0.5"/>
    <global azimuth="150" elevation="-35" offwidth="1280" offheight="720"/>
    <quality shadowsize="4096"/>
    <map force="0.01"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1=".9 .95 1" rgb2=".4 .5 .7" width="800" height="800"/>
    <texture type="2d" name="floor_tex" builtin="checker" mark="edge"
      rgb1=".85 .85 .85" rgb2=".7 .7 .7" markrgb=".5 .5 .5" width="300" height="300"/>
    <material name="floor_mat" texture="floor_tex" texuniform="true" texrepeat="10 10" reflectance="0.1"/>
    <material name="wall_mat" rgba="0.75 0.75 0.8 1"/>
    <material name="obstacle_mat" rgba="0.6 0.5 0.4 1"/>
    <material name="goal_mat" rgba="0.2 0.9 0.3 0.7"/>
  </asset>

  <worldbody>
    <!-- Floor -->
    <geom name="floor" size="0 0 0.01" type="plane" material="floor_mat"
      contype="1" conaffinity="0" priority="1" friction="0.6" condim="3"/>

    <!-- ============================================================ -->
    <!-- Room A (Start area) — centered around (0, 0)                 -->
    <!-- 4m x 3m room                                                  -->
    <!-- ============================================================ -->
    <!-- Room A — North wall -->
    <geom name="roomA_N" type="box" size="2.0 0.05 0.6" pos="0 1.5 0.6"
      material="wall_mat" group="0" contype="0" conaffinity="0"/>
    <!-- Room A — South wall -->
    <geom name="roomA_S" type="box" size="2.0 0.05 0.6" pos="0 -1.5 0.6"
      material="wall_mat" group="0" contype="0" conaffinity="0"/>
    <!-- Room A — West wall -->
    <geom name="roomA_W" type="box" size="0.05 1.5 0.6" pos="-2.0 0 0.6"
      material="wall_mat" group="0" contype="0" conaffinity="0"/>
    <!-- Room A — East wall (with doorway gap 1.2m wide) -->
    <geom name="roomA_E_top" type="box" size="0.05 0.4 0.6" pos="2.0 1.1 0.6"
      material="wall_mat" group="0" contype="0" conaffinity="0"/>
    <geom name="roomA_E_bot" type="box" size="0.05 0.4 0.6" pos="2.0 -1.1 0.6"
      material="wall_mat" group="0" contype="0" conaffinity="0"/>

    <!-- ============================================================ -->
    <!-- Corridor — from Room A door to Room B, L-shaped              -->
    <!-- Segment 1: East (x: 2 to 6, y: -1 to 1)                    -->
    <!-- Segment 2: South (x: 5 to 7, y: -1 to -5)                  -->
    <!-- ============================================================ -->
    <!-- Corridor seg1 — North wall -->
    <geom name="corr1_N" type="box" size="2.0 0.05 0.6" pos="4.0 1.0 0.6"
      material="wall_mat" group="0" contype="0" conaffinity="0"/>
    <!-- Corridor seg1 — South wall (partial, leaves opening for seg2) -->
    <geom name="corr1_S" type="box" size="1.0 0.05 0.6" pos="3.0 -1.0 0.6"
      material="wall_mat" group="0" contype="0" conaffinity="0"/>
    <!-- Corridor corner — East wall of seg1 / North wall of seg2 -->
    <geom name="corner_E" type="box" size="0.05 1.0 0.6" pos="6.0 0.0 0.6"
      material="wall_mat" group="0" contype="0" conaffinity="0"/>
    <!-- Corridor seg2 — East wall -->
    <geom name="corr2_E" type="box" size="0.05 2.0 0.6" pos="7.0 -3.0 0.6"
      material="wall_mat" group="0" contype="0" conaffinity="0"/>
    <!-- Corridor seg2 — West wall -->
    <geom name="corr2_W" type="box" size="0.05 1.5 0.6" pos="4.0 -2.5 0.6"
      material="wall_mat" group="0" contype="0" conaffinity="0"/>

    <!-- ============================================================ -->
    <!-- Room B (Goal area) — centered around (5.5, -5)               -->
    <!-- 4m x 3m room                                                  -->
    <!-- ============================================================ -->
    <!-- Room B — South wall -->
    <geom name="roomB_S" type="box" size="2.0 0.05 0.6" pos="5.5 -6.5 0.6"
      material="wall_mat" group="0" contype="0" conaffinity="0"/>
    <!-- Room B — West wall -->
    <geom name="roomB_W" type="box" size="0.05 1.25 0.6" pos="3.5 -5.25 0.6"
      material="wall_mat" group="0" contype="0" conaffinity="0"/>
    <!-- Room B — East wall -->
    <geom name="roomB_E" type="box" size="0.05 1.75 0.6" pos="7.5 -5.25 0.6"
      material="wall_mat" group="0" contype="0" conaffinity="0"/>
    <!-- Room B — North wall (with doorway) -->
    <geom name="roomB_N_left" type="box" size="0.5 0.05 0.6" pos="4.0 -4.0 0.6"
      material="wall_mat" group="0" contype="0" conaffinity="0"/>
    <geom name="roomB_N_right" type="box" size="0.5 0.05 0.6" pos="7.0 -4.0 0.6"
      material="wall_mat" group="0" contype="0" conaffinity="0"/>

    <!-- ============================================================ -->
    <!-- Obstacles — furniture in corridor and rooms                   -->
    <!-- ============================================================ -->
    <!-- Table in corridor -->
    <geom name="table1" type="box" size="0.4 0.25 0.35" pos="3.5 0.0 0.35"
      material="obstacle_mat" group="0" contype="0" conaffinity="0"/>
    <!-- Boxes in corridor -->
    <geom name="box1" type="box" size="0.25 0.25 0.25" pos="5.5 -2.0 0.25"
      material="obstacle_mat" group="0" contype="0" conaffinity="0"/>
    <!-- Chair in Room B -->
    <geom name="chair1" type="box" size="0.2 0.2 0.3" pos="4.5 -5.5 0.3"
      material="obstacle_mat" group="0" contype="0" conaffinity="0"/>
    <!-- Shelf in Room A -->
    <geom name="shelf1" type="box" size="0.15 0.6 0.4" pos="-1.5 0 0.4"
      material="obstacle_mat" group="0" contype="0" conaffinity="0"/>

    <!-- ============================================================ -->
    <!-- Goal marker (visual only, no collision)                       -->
    <!-- ============================================================ -->
    <geom name="goal_vis" type="sphere" size="0.15" pos="5.5 -5.5 0.15"
      material="goal_mat" contype="0" conaffinity="0"/>

    <!-- Light sources -->
    <light name="top_light" pos="3 -2 4" dir="0 0 -1" diffuse="0.8 0.8 0.8"
      specular="0.3 0.3 0.3" castshadow="true"/>
    <light name="fill_light" pos="-1 0 3" dir="0.3 -0.2 -1" diffuse="0.4 0.4 0.4"
      castshadow="false"/>
  </worldbody>

  <include file="../robots/go1_playground/xmls/sensor_feet.xml"/>

  <keyframe>
    <key name="home" qpos="
    0 0 0.278
    1 0 0 0
    0.1 0.9 -1.8
    -0.1 0.9 -1.8
    0.1 0.9 -1.8
    -0.1 0.9 -1.8"
      ctrl="0.1 0.9 -1.8 -0.1 0.9 -1.8 0.1 0.9 -1.8 -0.1 0.9 -1.8"/>
  </keyframe>
</mujoco>
